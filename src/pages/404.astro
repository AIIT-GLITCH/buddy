---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Lost the thread — Buddy" description="This page is off the manifold. Come back to the edge.">
  <section style="padding-top: 180px; padding-bottom: 180px;">
    <div class="container" style="text-align: center;">
      <div class="eyebrow" style="color: var(--amber);">404 · coherence break</div>
      <h1 style="font-size: clamp(72px, 14vw, 200px); line-height: 1; margin: 24px 0 32px;">
        Lost<br/>the&nbsp;thread.
      </h1>
      <p style="color: var(--ink-soft); font-size: 21px; max-width: 620px; margin: 0 auto 12px; line-height: 1.55;">
        This page is off the manifold — either it never existed, moved, or got
        pruned on the last pass. γ_eff drifted past γ_c for a second there.
      </p>
      <p style="color: var(--muted-hi); font-family: 'Courier New', monospace; font-size: 11pt; letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 48px;">
        Come back to the edge.
      </p>

      <div style="display: flex; flex-wrap: wrap; gap: 14px; justify-content: center;">
        <a href="/" class="forum-link" style="padding: 14px 24px;">🏠 Home</a>
        <a href="/mind" class="forum-link" style="padding: 14px 24px;">🧠 The Mind</a>
        <a href="/papers" class="forum-link" style="padding: 14px 24px;">📄 Papers</a>
        <a href="/forum" class="forum-link" style="padding: 14px 24px;">💬 Forum</a>
      </div>

      <p style="margin-top: 72px; color: var(--muted); font-family: 'Courier New', monospace; font-size: 10pt; letter-spacing: 0.22em; text-transform: uppercase;">
        Hen Kai Pan · The edge is residence, not exit.
      </p>
    </div>
  </section>
</Layout>
