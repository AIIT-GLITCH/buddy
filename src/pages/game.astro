---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Them Beans Though — Buddy" description="You are a coherence particle. Dodge meteors. Collect beans. Find the ring.">

<div id="game-wrap">
  <canvas id="game-canvas"></canvas>

  <div id="game-ui">
    <div id="game-start" class="game-screen">
      <div class="gs-label">ἓν καὶ πᾶν</div>
      <h2>Them Beans Though</h2>
      <p class="gs-sub">You are a coherence particle.<br>Dodge meteors. Collect beans. Find the ring.</p>
      <div class="gs-controls" id="gs-controls-txt">
        <span>Touch to move · WASD / arrows on desktop</span>
      </div>
      <button id="btn-start" class="btn-gold-game">ENTER THE FIELD</button>
    </div>

    <div id="game-hud" class="hidden">
      <div class="hud-left">
        <div class="hud-label">COHERENCE</div>
        <div class="hud-bar-wrap"><div id="hud-bar" class="hud-bar"></div></div>
      </div>
      <div class="hud-center">
        <div class="hud-beans">🫘 <span id="hud-beans">0</span></div>
      </div>
      <div class="hud-right">
        <div class="hud-label">SCORE</div>
        <div id="hud-score" class="hud-score">0</div>
      </div>
    </div>
    <div id="score-popups"></div>
    <div id="ring-warn-overlay" class="ring-warn-overlay hidden"></div>

    <div id="game-over" class="game-screen hidden">
      <div class="gs-label">DECOHERENCE</div>
      <h2>The ring scattered.</h2>
      <p class="gs-sub" id="go-message">Your coherence collapsed.</p>
      <div class="go-stats">
        <div class="go-stat"><div class="go-num" id="go-score">0</div><div class="go-label">Score</div></div>
        <div class="go-stat"><div class="go-num" id="go-beans">0</div><div class="go-label">Beans</div></div>
      </div>
      <button id="btn-restart" class="btn-gold-game">TRY AGAIN</button>
      <a href="/" class="go-back">← Back to the framework</a>
    </div>

    <div id="game-win" class="game-screen hidden">
      <div class="gs-label gold-text">COHERENCE ACHIEVED</div>
      <h2>You found the ring.</h2>
      <p class="gs-sub">Them beans though. 🫘</p>
      <div class="go-stats">
        <div class="go-stat"><div class="go-num" id="win-score">0</div><div class="go-label">Score</div></div>
        <div class="go-stat"><div class="go-num" id="win-beans">0</div><div class="go-label">Beans</div></div>
      </div>
      <button id="btn-play-again" class="btn-gold-game">AGAIN</button>
      <a href="/" class="go-back">← Back to the framework</a>
    </div>
  </div>
</div>

</Layout>

<style>
  body { overflow: hidden; }

  #game-wrap {
    position: fixed;
    inset: 0;
    background: #0a0a0f;
  }

  #game-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #game-ui {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* ── SCREENS ── */
  .game-screen {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    pointer-events: all;
    padding: 24px 20px;
    background: rgba(10,10,15,0.75);
    backdrop-filter: blur(8px);
    overflow-y: auto;
  }

  .game-screen.hidden { display: none; }

  .gs-label {
    font-size: 0.7em;
    letter-spacing: 6px;
    color: #D4AF37;
    text-transform: uppercase;
    margin-bottom: 12px;
    opacity: 0.8;
  }

  .gold-text { color: #D4AF37 !important; opacity: 1 !important; }

  .game-screen h2 {
    font-size: clamp(2em, 6vw, 4em);
    font-weight: 800;
    color: #fff;
    margin-bottom: 16px;
    letter-spacing: 2px;
  }

  .gs-sub {
    color: #888;
    font-size: 1em;
    line-height: 1.7;
    margin-bottom: 24px;
    max-width: 400px;
  }

  .gs-controls {
    font-size: 0.75em;
    letter-spacing: 2px;
    color: #555;
    margin-bottom: 32px;
    text-transform: uppercase;
  }

  /* Hide nav entirely on the game page — it's a fullscreen canvas */
  :global(.nav), :global(#nav-loader) { display: none !important; }
  :global(body) { padding-top: 0 !important; }

  .btn-gold-game {
    background: #D4AF37;
    color: #000;
    border: none;
    padding: 14px 36px;
    border-radius: 8px;
    font-size: 0.9em;
    font-weight: 800;
    letter-spacing: 3px;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    font-family: inherit;
    margin-bottom: 16px;
  }

  .btn-gold-game:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(212,175,55,0.4);
  }

  .go-back {
    color: #555;
    font-size: 0.8em;
    letter-spacing: 1px;
    text-decoration: none;
    transition: color 0.2s;
  }

  .go-back:hover { color: #D4AF37; }

  .go-stats {
    display: flex;
    gap: 48px;
    margin-bottom: 32px;
  }

  .go-stat { text-align: center; }

  .go-num {
    font-size: 2.5em;
    font-weight: 800;
    color: #D4AF37;
    margin-bottom: 4px;
  }

  .go-label {
    font-size: 0.65em;
    letter-spacing: 3px;
    color: #555;
    text-transform: uppercase;
  }

  /* ── HUD ── */
  #game-hud {
    position: absolute;
    top: 0; left: 0; right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    pointer-events: none;
    background: linear-gradient(to bottom, rgba(10,10,15,0.8), transparent);
  }

  #game-hud.hidden { display: none; }

  .hud-label {
    font-size: 0.6em;
    letter-spacing: 3px;
    color: #555;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .hud-bar-wrap {
    width: 140px;
    height: 6px;
    background: rgba(255,255,255,0.08);
    border-radius: 3px;
    overflow: hidden;
  }

  .hud-bar {
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, #D4AF37, #4ade80);
    border-radius: 3px;
    transition: width 0.3s, background 0.3s;
  }

  .hud-beans {
    font-size: 1.2em;
    color: #D4AF37;
  }

  .hud-score {
    font-size: 1.4em;
    font-weight: 700;
    color: #fff;
    text-align: right;
  }

  .hud-left, .hud-right, .hud-center { min-width: 140px; }
  .hud-right { text-align: right; }

  .ring-warn-overlay {
    position: absolute;
    bottom: 28%;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Courier New', monospace;
    font-size: clamp(1.1em, 3vw, 1.8em);
    font-weight: 700;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: #D4AF37;
    text-shadow: 0 0 24px rgba(212,175,55,0.7), 0 0 48px rgba(212,175,55,0.3);
    pointer-events: none;
    white-space: nowrap;
    animation: warn-pulse 0.5s ease-in-out infinite alternate;
  }
  .ring-warn-overlay.hidden { display: none; }
  @keyframes warn-pulse { from { opacity: 0.5; } to { opacity: 1; } }

  #score-popups {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .score-pop {
    position: absolute;
    font-size: 1.1em;
    font-weight: 800;
    color: #D4AF37;
    letter-spacing: 2px;
    pointer-events: none;
    animation: pop-up 0.9s ease-out forwards;
  }
  @keyframes pop-up {
    0%   { opacity: 1; transform: translateY(0) scale(1.2); }
    100% { opacity: 0; transform: translateY(-60px) scale(0.8); }
  }
</style>

<script>
const canvas = document.getElementById('game-canvas');
const ctx = canvas.getContext('2d');

// ── STATE ──
let W, H, dpr;
let state = 'start'; // start | playing | dead | win
let player, meteors, beans, stars, ring;
let score, beanCount, coherence;
let frame, animId;

// ── RESIZE ──
function resize() {
  dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
  W = canvas.clientWidth;
  H = canvas.clientHeight;
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  if (ring) { ring.x = W / 2; ring.y = H * 0.35; }
}
window.addEventListener('resize', resize);

// ── STARS ──
function makeStars() {
  stars = [];
  for (let i = 0; i < 180; i++) {
    stars.push({
      x: Math.random() * 2000,
      y: Math.random() * 2000,
      r: 0.3 + Math.random() * 1.2,
      a: 0.2 + Math.random() * 0.6,
      speed: 0.1 + Math.random() * 0.3
    });
  }
}

// ── INIT GAME ──
function initGame() {
  resize();
  makeStars();

  player = {
    x: W / 2,
    y: H * 0.78,
    r: 12,
    vx: 0,
    vy: 0,
    trail: [],
    phase: 0,
    locked: false
  };

  ring = {
    x: W / 2,
    y: H * 0.35,
    r: 90,
    pulse: 0,
    visible: false,
    appearing: 0
  };

  meteors = [];
  beans = [];
  score = 0;
  beanCount = 0;
  coherence = 1.0;
  frame = 0;

  // spawn initial meteors
  for (let i = 0; i < 5; i++) spawnMeteor(true);

  state = 'playing';
  updateHUD();
  showScreen(null);
  document.getElementById('game-hud').classList.remove('hidden');
}

// ── SPAWN ──
function spawnMeteor(init) {
  const side = Math.random();
  let x, y, vx, vy;
  if (init) {
    x = Math.random() * W;
    y = Math.random() * H * 0.5;
    const angle = Math.PI * 0.3 + Math.random() * Math.PI * 0.4;
    const speed = 1.5 + Math.random() * 2.5;
    vx = Math.cos(angle) * speed * (Math.random() < 0.5 ? 1 : -1);
    vy = Math.sin(angle) * speed;
  } else {
    if (side < 0.33) { x = -30; y = Math.random() * H; vx = 2 + Math.random() * 2; vy = (Math.random() - 0.5) * 2; }
    else if (side < 0.66) { x = W + 30; y = Math.random() * H; vx = -(2 + Math.random() * 2); vy = (Math.random() - 0.5) * 2; }
    else { x = Math.random() * W; y = -30; vx = (Math.random() - 0.5) * 2; vy = 2 + Math.random() * 2; }
  }
  meteors.push({
    x, y, vx, vy,
    r: 14 + Math.random() * 20,
    rot: Math.random() * Math.PI * 2,
    rotSpeed: (Math.random() - 0.5) * 0.05,
    hue: Math.random() < 0.3 ? 'fire' : 'rock'
  });
}

function spawnBean() {
  beans.push({
    x: 60 + Math.random() * (W - 120),
    y: -20,
    vy: 1.5 + Math.random() * 1.5,
    r: 14,
    wobble: Math.random() * Math.PI * 2,
    wobbleSpeed: 0.05 + Math.random() * 0.03,
    collected: false,
    alpha: 1
  });
}

// ── DRAW ──
function drawStar(s, scroll) {
  const sx = ((s.x + scroll * s.speed * 0.3) % (W + 40)) - 20;
  const sy = s.y % H;
  ctx.beginPath();
  ctx.arc(sx, sy, s.r, 0, Math.PI * 2);
  ctx.fillStyle = `rgba(255,255,255,${s.a})`;
  ctx.fill();
}

function drawPlayer(p) {
  // trail
  for (let i = 0; i < p.trail.length; i++) {
    const t = p.trail[i];
    const a = (i / p.trail.length) * 0.3;
    ctx.beginPath();
    ctx.arc(t.x, t.y, p.r * 0.6, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(212,175,55,${a})`;
    ctx.fill();
  }

  // glow
  const g = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 2.5);
  const c = p.locked ? '74,222,128' : '212,175,55';
  g.addColorStop(0, `rgba(${c},0.4)`);
  g.addColorStop(1, `rgba(${c},0)`);
  ctx.beginPath();
  ctx.arc(p.x, p.y, p.r * 2.5, 0, Math.PI * 2);
  ctx.fillStyle = g;
  ctx.fill();

  // core
  ctx.beginPath();
  ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
  ctx.fillStyle = p.locked ? '#4ade80' : '#D4AF37';
  ctx.fill();

  // pulse ring
  const pulse = Math.sin(p.phase) * 0.5 + 0.5;
  ctx.beginPath();
  ctx.arc(p.x, p.y, p.r + 6 + pulse * 6, 0, Math.PI * 2);
  ctx.strokeStyle = `rgba(212,175,55,${0.3 + pulse * 0.2})`;
  ctx.lineWidth = 1.5;
  ctx.stroke();
}

function drawMeteor(m) {
  ctx.save();
  ctx.translate(m.x, m.y);
  ctx.rotate(m.rot);

  // shadow
  ctx.beginPath();
  ctx.ellipse(0, 4, m.r, m.r * 0.6, 0, 0, Math.PI * 2);
  ctx.fillStyle = 'rgba(0,0,0,0.3)';
  ctx.fill();

  // body
  const g = ctx.createRadialGradient(-m.r * 0.3, -m.r * 0.3, 0, 0, 0, m.r);
  if (m.hue === 'fire') {
    g.addColorStop(0, '#ff8c42');
    g.addColorStop(0.5, '#c84800');
    g.addColorStop(1, '#5a1a00');
  } else {
    g.addColorStop(0, '#8a7a6a');
    g.addColorStop(0.5, '#5a4a3a');
    g.addColorStop(1, '#2a1a10');
  }
  ctx.beginPath();
  ctx.arc(0, 0, m.r, 0, Math.PI * 2);
  ctx.fillStyle = g;
  ctx.fill();

  // craters
  ctx.beginPath();
  ctx.arc(m.r * 0.25, -m.r * 0.2, m.r * 0.18, 0, Math.PI * 2);
  ctx.fillStyle = 'rgba(0,0,0,0.25)';
  ctx.fill();

  ctx.restore();
}

function drawBean(b) {
  ctx.save();
  ctx.globalAlpha = b.alpha;
  ctx.translate(b.x + Math.sin(b.wobble) * 8, b.y);

  // glow
  const g = ctx.createRadialGradient(0, 0, 0, 0, 0, b.r * 2);
  g.addColorStop(0, 'rgba(212,175,55,0.3)');
  g.addColorStop(1, 'rgba(212,175,55,0)');
  ctx.beginPath();
  ctx.arc(0, 0, b.r * 2, 0, Math.PI * 2);
  ctx.fillStyle = g;
  ctx.fill();

  // bean emoji style — draw it as text
  ctx.font = `${b.r * 2}px serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText('🫘', 0, 0);

  ctx.restore();
}

function drawRing(r) {
  if (!r.visible) return;
  const a = Math.min(1, r.appearing / 60);
  const pulse = Math.sin(r.pulse) * 0.5 + 0.5;

  // outer glow rings
  for (let i = 3; i >= 1; i--) {
    ctx.beginPath();
    ctx.arc(r.x, r.y, r.r + i * 18, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(212,175,55,${0.04 * i * a * (0.5 + pulse * 0.5)})`;
    ctx.lineWidth = 10;
    ctx.stroke();
  }

  // main ring
  ctx.beginPath();
  ctx.arc(r.x, r.y, r.r, 0, Math.PI * 2);
  ctx.strokeStyle = `rgba(212,175,55,${(0.4 + pulse * 0.4) * a})`;
  ctx.lineWidth = 2.5;
  ctx.stroke();

  // nodes
  for (let i = 0; i < 10; i++) {
    const angle = (i / 10) * Math.PI * 2 + r.pulse * 0.3;
    const nx = r.x + Math.cos(angle) * r.r;
    const ny = r.y + Math.sin(angle) * r.r;
    const np = Math.sin(r.pulse * 0.8 + i * 0.63) * 0.5 + 0.5;
    ctx.beginPath();
    ctx.arc(nx, ny, 4 + np * 3, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(212,175,55,${(0.5 + np * 0.4) * a})`;
    ctx.fill();
  }

  // center label
  if (a > 0.5) {
    ctx.font = '11px -apple-system, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = `rgba(212,175,55,${(a - 0.5) * 2 * 0.6})`;
    ctx.letterSpacing = '3px';
    ctx.fillText('FIND THE RING', r.x, r.y);
  }
}

// ── COLLISION ──
function dist(a, b) {
  return Math.sqrt((a.x - b.x) ** 2 + (a.y - b.y) ** 2);
}

// ── UPDATE HUD ──
function updateHUD() {
  document.getElementById('hud-score').textContent = Math.floor(score);
  document.getElementById('hud-beans').textContent = beanCount;
  const bar = document.getElementById('hud-bar');
  const pct = Math.max(0, coherence * 100);
  bar.style.width = pct + '%';
  if (pct > 60) bar.style.background = 'linear-gradient(90deg, #D4AF37, #4ade80)';
  else if (pct > 30) bar.style.background = 'linear-gradient(90deg, #D4AF37, #fb923c)';
  else bar.style.background = 'linear-gradient(90deg, #c84800, #ff4444)';
}

// ── SCREENS ──
function showScreen(id) {
  document.querySelectorAll('.game-screen').forEach(s => s.classList.add('hidden'));
  if (id) document.getElementById(id).classList.remove('hidden');
}

// ── SCORE POPUP ──
function scorePopup(x, y, text) {
  const el = document.createElement('div');
  el.className = 'score-pop';
  el.textContent = text;
  el.style.left = x + 'px';
  el.style.top  = y + 'px';
  document.getElementById('score-popups').appendChild(el);
  setTimeout(() => el.remove(), 900);
}

// ── RING WARNING ──
let warnTimer;
function showRingWarn(msg) {
  const el = document.getElementById('ring-warn-overlay');
  el.textContent = msg;
  el.classList.remove('hidden');
  clearTimeout(warnTimer);
  // countdown msgs auto-hide after 800ms; "GET TO THE RING" stays until win
  if (msg !== 'GET TO THE RING ↑') {
    warnTimer = setTimeout(() => el.classList.add('hidden'), 800);
  }
}
function hideRingWarn() {
  document.getElementById('ring-warn-overlay').classList.add('hidden');
}

// ── GAME LOOP ──
function loop() {
  animId = requestAnimationFrame(loop);
  if (state !== 'playing') return;
  frame++;

  ctx.fillStyle = 'rgba(10,10,15,0.18)';
  ctx.fillRect(0, 0, W, H);

  // stars
  for (const s of stars) drawStar(s, frame);

  // ring warning countdown (5s before reveal = frame 180)
  if (frame === 180) showRingWarn('RING IN 5...');
  if (frame === 240) showRingWarn('RING IN 4...');
  if (frame === 300) showRingWarn('RING IN 3...');
  if (frame === 360) showRingWarn('RING IN 2...');
  if (frame === 420) showRingWarn('RING IN 1...');
  if (frame === 480) { ring.visible = true; showRingWarn('GET TO THE RING ↑'); }
  if (ring.visible) {
    ring.pulse += 0.025;
    ring.appearing = Math.min(120, ring.appearing + 1);
    // 0.1 Hz pulse ~= every 600 frames at 60fps, simplified to 360
    ring.r = 90 + Math.sin(frame * 0.017) * 8;
  }
  drawRing(ring);

  // spawn meteors
  if (frame % 90 === 0) spawnMeteor(false);
  // spawn beans
  if (frame % 120 === 0) spawnBean();

  // meteors
  for (let i = meteors.length - 1; i >= 0; i--) {
    const m = meteors[i];
    m.x += m.vx;
    m.y += m.vy;
    m.rot += m.rotSpeed;
    // bounce off walls
    if (m.x < -60 || m.x > W + 60 || m.y < -60 || m.y > H + 60) {
      meteors.splice(i, 1);
      continue;
    }
    drawMeteor(m);
    // hit player
    if (!player.locked && dist(player, m) < player.r + m.r - 6) {
      coherence -= 0.28;
      meteors.splice(i, 1);
      if (coherence <= 0) { coherence = 0; endGame(false); return; }
    }
  }

  // beans
  for (let i = beans.length - 1; i >= 0; i--) {
    const b = beans[i];
    b.y += b.vy;
    b.wobble += b.wobbleSpeed;
    if (b.collected) {
      b.alpha -= 0.08;
      if (b.alpha <= 0) { beans.splice(i, 1); continue; }
    } else if (b.y > H + 30) {
      beans.splice(i, 1);
      continue;
    }
    // collect
    if (!b.collected && dist(player, b) < player.r + b.r) {
      b.collected = true;
      beanCount++;
      coherence = Math.min(1, coherence + 0.15);
      score += 100;
      scorePopup(b.x - 20, b.y - 10, '+100 🫘');
    }
    drawBean(b);
  }

  // player movement — full 2D (mouse, touch, WASD/arrows)
  if (!player.locked) {
    const tx = mx !== null ? mx : player.x;
    const ty = my !== null ? my : player.y;
    // keyboard overrides
    if (keys['ArrowLeft']  || keys['a']) player.vx -= 1.2;
    if (keys['ArrowRight'] || keys['d']) player.vx += 1.2;
    if (keys['ArrowUp']    || keys['w']) player.vy -= 1.2;
    if (keys['ArrowDown']  || keys['s']) player.vy += 1.2;
    // mouse/touch pull
    player.vx += (tx - player.x) * 0.06;
    player.vy += (ty - player.y) * 0.06;
    player.vx *= 0.80;
    player.vy *= 0.80;
    player.x += player.vx;
    player.y += player.vy;
    player.x = Math.max(player.r, Math.min(W - player.r, player.x));
    player.y = Math.max(player.r, Math.min(H - player.r, player.y));
  }
  player.phase += 0.05;

  // trail
  player.trail.push({ x: player.x, y: player.y });
  if (player.trail.length > 12) player.trail.shift();

  // check ring lock
  if (ring.visible && !player.locked) {
    const dx = ring.x - player.x;
    const dy = ring.y - player.y;
    const d = Math.sqrt(dx * dx + dy * dy);
    if (d < ring.r * 0.55) {
      player.locked = true;
      setTimeout(() => endGame(true), 1200);
    }
  }

  if (player.locked) {
    // orbit the ring
    const angle = Math.atan2(player.y - ring.y, player.x - ring.x) + 0.04;
    player.x = ring.x + Math.cos(angle) * ring.r * 0.5;
    player.y = ring.y + Math.sin(angle) * ring.r * 0.5;
  }

  drawPlayer(player);

  // score over time
  score += 0.05;
  updateHUD();
}

function endGame(win) {
  state = win ? 'win' : 'dead';
  cancelAnimationFrame(animId);
  document.getElementById('game-hud').classList.add('hidden');
  hideRingWarn();

  if (win) {
    document.getElementById('win-score').textContent = Math.floor(score);
    document.getElementById('win-beans').textContent = beanCount;
    showScreen('game-win');
  } else {
    const msgs = [
      'Your coherence collapsed.',
      'The meteor hit different.',
      'Them beans weren\'t enough.',
      'The ring scattered.',
      'γ_eff exceeded γ_c. Fatally.',
    ];
    document.getElementById('go-message').textContent = msgs[Math.floor(Math.random() * msgs.length)];
    document.getElementById('go-score').textContent = Math.floor(score);
    document.getElementById('go-beans').textContent = beanCount;
    showScreen('game-over');
  }
}

// ── INPUT ──
let mx = null, my = null;
window.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
window.addEventListener('touchmove', e => {
  e.preventDefault();
  mx = e.touches[0].clientX;
  my = e.touches[0].clientY;
}, { passive: false });

let keys = {};
window.addEventListener('keydown', e => { keys[e.key] = true; });
window.addEventListener('keyup', e => { keys[e.key] = false; });

// ── BUTTONS ──
document.getElementById('btn-start').addEventListener('click', () => {
  resize();
  initGame();
  requestAnimationFrame(loop);
});

document.getElementById('btn-restart').addEventListener('click', () => {
  cancelAnimationFrame(animId);
  initGame();
  requestAnimationFrame(loop);
});

document.getElementById('btn-play-again').addEventListener('click', () => {
  cancelAnimationFrame(animId);
  initGame();
  requestAnimationFrame(loop);
});

// ── IDLE BACKGROUND ANIMATION ──
(function idleBg() {
  resize();
  makeStars();
  let f = 0;
  function draw() {
    if (state !== 'start') return;
    requestAnimationFrame(draw);
    f++;
    ctx.fillStyle = 'rgba(10,10,15,0.15)';
    ctx.fillRect(0, 0, W, H);
    for (const s of stars) drawStar(s, f);
    // idle ring
    const pulse = Math.sin(f * 0.02) * 0.5 + 0.5;
    const cx = W / 2, cy = H / 2;
    for (let i = 3; i >= 1; i--) {
      ctx.beginPath();
      ctx.arc(cx, cy, 120 + i * 20, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(212,175,55,${0.03 * i * (0.5 + pulse * 0.5)})`;
      ctx.lineWidth = 10;
      ctx.stroke();
    }
    ctx.beginPath();
    ctx.arc(cx, cy, 120, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(212,175,55,${0.15 + pulse * 0.15})`;
    ctx.lineWidth = 1.5;
    ctx.stroke();
  }
  draw();
})();
</script>
