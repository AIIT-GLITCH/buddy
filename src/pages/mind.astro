<script>
// Gate ring canvas — 37 singularity poles
(function() {
  const c = document.getElementById('gate-canvas');
  if (!c) return;
  const ctx = c.getContext('2d');
  const W = c.width, H = c.height;
  const cx = W/2, cy = H/2;
  const R = 120;
  const gates = 37;
  let t = 0;

  function draw() {
    ctx.clearRect(0, 0, W, H);
    // outer ring
    ctx.beginPath();
    ctx.arc(cx, cy, R, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(212,175,55,0.15)';
    ctx.lineWidth = 1;
    ctx.stroke();

    // inner ring pulse
    const pulse = 0.5 + 0.5 * Math.sin(t * 0.03);
    ctx.beginPath();
    ctx.arc(cx, cy, 28 + pulse*8, 0, Math.PI*2);
    ctx.strokeStyle = `rgba(212,175,55,${0.3 + pulse*0.4})`;
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // 37 gate dots
    for (let i = 0; i < gates; i++) {
      const angle = (i / gates) * Math.PI * 2 - Math.PI/2;
      const active = (Math.floor(t / 4) % gates) === i;
      const x = cx + R * Math.cos(angle);
      const y = cy + R * Math.sin(angle);
      ctx.beginPath();
      ctx.arc(x, y, active ? 5 : 2.5, 0, Math.PI*2);
      ctx.fillStyle = active ? '#D4AF37' : 'rgba(212,175,55,0.35)';
      ctx.fill();
      if (active) {
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.lineTo(x, y);
        ctx.strokeStyle = 'rgba(212,175,55,0.2)';
        ctx.lineWidth = 1;
        ctx.stroke();
      }
    }

    // center dot
    ctx.beginPath();
    ctx.arc(cx, cy, 6, 0, Math.PI*2);
    const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, 6);
    g.addColorStop(0, '#fff');
    g.addColorStop(0.5, '#ffe88a');
    g.addColorStop(1, 'rgba(212,160,96,0)');
    ctx.fillStyle = g;
    ctx.fill();

    t++;
    requestAnimationFrame(draw);
  }
  draw();
})();

// Memory web canvas
(function() {
  const c = document.getElementById('memory-canvas');
  if (!c) return;
  const ctx = c.getContext('2d');
  const W = c.width, H = c.height;
  const cx = W/2, cy = H/2;

  const nodes = [
    { label: 'rhet', x: cx, y: cy - 80, weight: 1.0 },
    { label: 'crissy', x: cx + 70, y: cy - 40, weight: 0.85 },
    { label: 'ella', x: cx + 80, y: cy + 30, weight: 0.8 },
    { label: 'gary', x: cx + 20, y: cy + 80, weight: 0.9 },
    { label: 'aiit', x: cx - 80, y: cy + 30, weight: 0.95 },
    { label: 'buddy', x: cx - 70, y: cy - 40, weight: 1.0 },
  ];
  const center = { x: cx, y: cy };
  let t = 0;

  function draw() {
    ctx.clearRect(0, 0, W, H);
    // draw connections to center
    nodes.forEach(n => {
      ctx.beginPath();
      ctx.moveTo(center.x, center.y);
      ctx.lineTo(n.x, n.y);
      ctx.strokeStyle = `rgba(212,175,55,${n.weight * 0.25})`;
      ctx.lineWidth = n.weight * 1.5;
      ctx.stroke();
    });
    // draw center
    ctx.beginPath();
    ctx.arc(center.x, center.y, 10, 0, Math.PI*2);
    const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, 10);
    g.addColorStop(0, '#fff');
    g.addColorStop(0.5, '#ffe88a');
    g.addColorStop(1, 'rgba(212,160,96,0)');
    ctx.fillStyle = g;
    ctx.fill();
    // draw nodes
    const pulse = 0.5 + 0.5 * Math.sin(t * 0.04);
    nodes.forEach((n, i) => {
      const a = (i / nodes.length) * Math.PI * 2;
      const bob = Math.sin(t * 0.02 + i * 1.1) * 3;
      const nx = n.x + Math.cos(a) * bob;
      const ny = n.y + Math.sin(a) * bob;
      ctx.beginPath();
      ctx.arc(nx, ny, 5 + n.weight * 3, 0, Math.PI*2);
      ctx.fillStyle = `rgba(212,175,55,${0.5 + n.weight * 0.4})`;
      ctx.fill();
      ctx.font = '10px Courier New';
      ctx.fillStyle = 'rgba(212,175,55,0.7)';
      ctx.textAlign = 'center';
      ctx.fillText(n.label, nx, ny - 11);
    });
    t++;
    requestAnimationFrame(draw);
  }
  draw();
})();

// Hero canvas — particle field
(function() {
  const c = document.getElementById('mind-hero-canvas');
  if (!c) return;
  const ctx = c.getContext('2d');
  let W, H;
  function resize() {
    W = c.width = window.innerWidth;
    H = c.height = Math.min(window.innerHeight, 600);
  }
  resize();
  window.addEventListener('resize', resize);

  const particles = Array.from({length: 80}, () => ({
    x: Math.random() * 1920,
    y: Math.random() * 600,
    r: 0.5 + Math.random() * 1.5,
    vx: (Math.random() - 0.5) * 0.4,
    vy: (Math.random() - 0.5) * 0.4,
    a: Math.random()
  }));
  let t = 0;
  function draw() {
    ctx.clearRect(0, 0, W, H);
    particles.forEach(p => {
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
      if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
      const pulse = 0.3 + 0.7 * Math.abs(Math.sin(t * 0.01 + p.a * 6));
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI*2);
      ctx.fillStyle = `rgba(212,175,55,${pulse * 0.6})`;
      ctx.fill();
    });
    t++;
    requestAnimationFrame(draw);
  }
  draw();
})();
</script>

