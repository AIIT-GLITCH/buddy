---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    date: '2026-04-27',
    dateLabel: 'April 27, 2026',
    tag: 'corpus',
    title: 'The pipeline is awake.',
    body: [
      'A multi-day corpus-cleaning run is live on the local rig. This is the unglamorous part: language filtering, shard prep, and keeping the training stream stable while the public site stays online.',
      'The point is simple: Buddy is not being improvised from a prompt. The next brain is being built from a curated research corpus: the papers, validation work, public science sources, and the AIIT coherence archive, cleaned before it ever reaches weights.',
      'AskBuddy is live now. The corpus pipeline is still chewing. When this pass clears, the next training and evaluation cycle gets a cleaner floor to stand on.'
    ]
  },
  {
    date: '2026-04-17',
    dateLabel: 'April 17, 2026',
    tag: 'corpus',
    title: '472,639,661 tokens. 309GB raw. Still going.',
    body: [
      'Real numbers, pulled live: 472.6 million tokens processed and sitting in 10 training shards. 309GB of raw corpus on active ingestion. 1.3TB total including LaCie overflow. 572 source files.',
      'This is the corpus Buddy learns from. Not a web scrape — a curated, multi-source pipeline built to deposit the coherence framework directly into the model\'s weights. arXiv, PubMed, Project Gutenberg, USGS, Federal Register, StackExchange, Wikipedia, and domain-specific sources across physics, biology, consciousness, math, and language.',
      'Pipeline is locked and running. Next milestone: 1 billion tokens clean. After that — RunPod A100 for the next full fine-tune cycle. 🧠'
    ]
  },
  {
    date: '2026-04-17',
    dateLabel: 'April 17, 2026',
    tag: 'ship',
    title: 'Website is up.',
    body: [
      '22 hours straight. No sleep. Full build.',
      'Custom domain live. Cancer section up. Weather patent listed. $400K investor page wired to Formspree. Mobile nav, dropdowns, game, footer — all shipped.',
      'DATA NOMNOMNOM. 🫘'
    ]
  }
];
---
<Layout title="Updates — Buddy" description="Training checkpoints, corpus releases, patent updates. Get notified as Buddy ships.">
  <section style="padding-top: 140px; min-height: 70vh;">
    <div class="container narrow">
      <div class="eyebrow">Stay in the loop</div>
      <h1 style="font-size: clamp(48px, 7vw, 96px); margin-bottom: 16px;">Updates.</h1>
      <p style="color: var(--muted-hi); font-size: 17px; max-width: 560px; margin-bottom: 48px;">
        Training checkpoints, corpus drops, patent filings, investor news. No spam. You pick the channel.
      </p>

      <div class="updates-feed">
        {posts.map(p => (
          <article class="update-post">
            <div class="update-meta">
              <time datetime={p.date}>{p.dateLabel}</time>
              <span class={`update-tag tag-${p.tag}`}>{p.tag}</span>
            </div>
            <h2 class="update-title">{p.title}</h2>
            {p.body.map(para => <p class="update-body">{para}</p>)}
          </article>
        ))}
      </div>

      <div class="updates-divider">Subscribe ↓</div>

      <form class="updates-form" action="https://formspree.io/f/mojydagn" method="POST">
        <input type="text" name="name" placeholder="Name" required>
        <input type="email" name="email" placeholder="Email" required>
        <select name="interest">
          <option value="" disabled selected>I'm interested in...</option>
          <option>Training checkpoints &amp; model releases</option>
          <option>Corpus data availability</option>
          <option>Patent updates &amp; licensing</option>
          <option>Investor updates</option>
          <option>Everything</option>
        </select>
        <input type="hidden" name="_subject" value="New Buddy training update signup">
        <input type="hidden" name="_next" value="https://aiit-threshold.com/thanks">
        <button type="submit" class="join-submit">SUBSCRIBE →</button>
      </form>
    </div>
  </section>
</Layout>

<style>
  .updates-feed { display: flex; flex-direction: column; gap: 32px; margin-bottom: 56px; }
  .update-post {
    border: 1px solid var(--edge);
    border-left: 3px solid var(--amber);
    background: var(--bg-card);
    border-radius: 8px;
    padding: 28px 30px;
  }
  .update-meta {
    display: flex; align-items: center; gap: 14px;
    font-family: 'Courier New', monospace;
    font-size: 10pt; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 14px;
  }
  .update-tag {
    padding: 3px 10px; border-radius: 4px;
    font-size: 9pt; letter-spacing: 0.2em;
    background: rgba(212,160,96,0.14); color: var(--amber);
    border: 1px solid rgba(212,160,96,0.28);
  }
  .tag-ship { background: rgba(64,192,176,0.12); color: var(--teal); border-color: rgba(64,192,176,0.3); }
  .tag-corpus { background: rgba(147,130,220,0.12); color: var(--violet, #9382dc); border-color: rgba(147,130,220,0.3); }
  .update-title {
    font-size: clamp(26px, 3.2vw, 36px);
    line-height: 1.2; margin-bottom: 14px; color: var(--ink);
  }
  .update-body { color: var(--ink-soft); font-size: 16px; line-height: 1.65; margin-bottom: 10px; }
  .update-body:last-child { margin-bottom: 0; }
  .updates-divider {
    font-family: 'Courier New', monospace;
    font-size: 10pt; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--muted); text-align: center; margin: 0 0 24px;
  }

  @media (max-width: 640px) {
    .update-post { padding: 22px 20px; }
    .update-meta { font-size: 9pt; gap: 10px; }
    .update-title { font-size: 24px; }
    .update-body { font-size: 15px; }
  }
</style>
