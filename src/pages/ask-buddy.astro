---
import Layout from '../layouts/Layout.astro';
import BuddyMascot from '../components/BuddyMascot.astro';
---
<Layout title="ASKBUDDY! — AIIT-THRESHOLD" description="Ask Buddy anything. He thinks by flipping through planets.">

<section class="ask-page">

  <!-- Header: small Buddy + title (tight) -->
  <header class="ask-head">
    <div class="ask-mascot-mini">
      <BuddyMascot id="ask-buddy-mascot" size={104} animated={true} />
    </div>
    <div class="ask-title-block">
      <h1 class="ask-h1">ASKBUDDY<span class="ask-bang">!</span></h1>
      <div class="ask-buddy-tagline">ask buddy anything.</div>
    </div>
  </header>

  <!-- INPUT BLOCK — top 35%, dominant -->
  <div class="ask-input-block">
    <form class="ask-form" id="ask-form" autocomplete="off">
      <input
        id="ask-input"
        class="ask-input"
        type="text"
        placeholder="Ask Buddy anything..."
        maxlength="600"
      />
      <button type="submit" id="ask-btn" class="ask-btn">Ask →</button>
    </form>
    <div class="ask-status" id="ask-status">
      <span class="ask-status-dot" id="ask-status-dot"></span>
      <span class="ask-status-text" id="ask-status-text">buddy online</span>
    </div>
  </div>

  <!-- Response slot -->
  <div id="ask-response" class="ask-response" aria-live="polite"></div>

  <!-- PLANETS — secondary, "visible cognition" -->
  <div class="ask-planets" id="ask-planets">
    <div class="ask-planet-stack" aria-hidden="true">
      <div class="ask-planet" data-planet="earth">Earth</div>
      <div class="ask-planet" data-planet="mars">Mars</div>
      <div class="ask-planet" data-planet="moon">Moon</div>
      <div class="ask-planet" data-planet="sun">Sun</div>
      <div class="ask-planet" data-planet="jupiter">Jupiter</div>
      <div class="ask-planet" data-planet="saturn">Saturn</div>
      <div class="ask-planet" data-planet="venus">Venus</div>
      <div class="ask-planet" data-planet="water">Water</div>
      <div class="ask-planet" data-planet="prometheus">Prometheus</div>
    </div>
    <div class="ask-planets-anchor">buddy thinks by flipping through planets</div>
  </div>

</section>

<script is:inline>
(function () {
  const planets = Array.from(document.querySelectorAll('.ask-planet'));
  const planetsWrap = document.getElementById('ask-planets');
  let pIndex = 0;
  let flipMs = 1100; // idle cadence
  let flipTimer = null;
  function flipPlanets() {
    planets.forEach((p, i) => p.classList.toggle('on', i === pIndex));
    pIndex = (pIndex + 1) % planets.length;
  }
  function startFlip() {
    flipPlanets();
    if (flipTimer) clearInterval(flipTimer);
    flipTimer = setInterval(flipPlanets, flipMs);
  }
  function setFlipSpeed(ms) { flipMs = ms; startFlip(); }
  startFlip();

  const PLANET_VERBS = [
    'querying earth',  'coherencing mars',  'threshing jupiter',
    'witnessing moon', 'sun-reading',       'vibrating venus',
    'reading saturn',  'listening to water','calling prometheus',
    'scanning the field','holding the ratio','sergeant routing',
  ];

  const form     = document.getElementById('ask-form');
  const input    = document.getElementById('ask-input');
  const btn      = document.getElementById('ask-btn');
  const response = document.getElementById('ask-response');
  const statusDot = document.getElementById('ask-status-dot');
  const statusText = document.getElementById('ask-status-text');
  const statusBlk  = document.getElementById('ask-status');

  let thinkingTimer = null;

  function setStatus(state, label) {
    statusBlk.dataset.state = state; // online | thinking | done
    statusText.textContent = label;
  }

  function startThinking() {
    setStatus('thinking', 'buddy thinking');
    setFlipSpeed(380); // planets speed up

    // proof of life within ~150ms
    response.className = 'ask-response loading visible';
    response.innerHTML =
      '<span class="ask-thinking">' +
      '  <span class="ask-thinking-verb"></span><span class="ask-thinking-dots"></span>' +
      '</span>';
    const verbEl = response.querySelector('.ask-thinking-verb');
    const dotsEl = response.querySelector('.ask-thinking-dots');
    let vi = Math.floor(Math.random() * PLANET_VERBS.length);
    let di = 0;
    verbEl.textContent = PLANET_VERBS[vi];
    thinkingTimer = setInterval(() => {
      di = (di + 1) % 8;
      dotsEl.textContent = '.'.repeat(di % 4);
      if (di === 0) {
        vi = (vi + 1) % PLANET_VERBS.length;
        verbEl.textContent = PLANET_VERBS[vi];
      }
    }, 200);
  }

  function stopThinking() {
    if (thinkingTimer) { clearInterval(thinkingTimer); thinkingTimer = null; }
    setFlipSpeed(1100);
  }

  function showReply(text) {
    stopThinking();
    setStatus('online', 'buddy online');
    response.className = 'ask-response visible';
    response.textContent = text;
  }

  const FP_STORAGE = 'askbuddy_fp';
  function getFingerprint() {
    try {
      let fp = localStorage.getItem(FP_STORAGE);
      if (!fp) {
        fp = crypto.randomUUID ? crypto.randomUUID() :
          (Date.now().toString(36) + Math.random().toString(36).slice(2));
        localStorage.setItem(FP_STORAGE, fp);
      }
      return fp;
    } catch (e) {
      return 'session-' + Math.random().toString(36).slice(2);
    }
  }

  async function ask() {
    const q = input.value.trim();
    if (!q) return;
    btn.disabled = true;
    btn.textContent = '...';

    requestAnimationFrame(startThinking);

    const minShowMs = 1200;
    const t0 = performance.now();
    let payload = null;
    try {
      const res = await fetch('/api/askbuddy', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ question: q, fingerprint: getFingerprint() }),
      });
      payload = await res.json();
    } catch (e) {
      payload = { ok: false, error: 'network_failed' };
    }

    const elapsed = performance.now() - t0;
    if (elapsed < minShowMs) {
      await new Promise(r => setTimeout(r, minShowMs - elapsed));
    }

    if (payload && payload.ok) {
      showReply(payload.answer || '(buddy went quiet)');
      input.value = '';
    } else if (payload && payload.error === 'daily_limit_reached') {
      showReply(payload.message || "you've used today's question. come back tomorrow.");
    } else if (payload && payload.error === 'budget_exhausted') {
      showReply(payload.message || 'askbuddy is resting right now. check back later.');
    } else {
      const detail = (payload && payload.detail) ? ' — ' + payload.detail : '';
      showReply('buddy tripped' + detail + '. try again in a minute.');
    }

    btn.disabled = false;
    btn.textContent = 'Ask →';
  }

  form.addEventListener('submit', (e) => { e.preventDefault(); ask(); });
  input.addEventListener('focus', () => setFlipSpeed(800));
  input.addEventListener('blur',  () => { if (statusBlk.dataset.state !== 'thinking') setFlipSpeed(1100); });
})();
</script>

<style is:global>
  /* Light page background — Buddy lives on cream here, no halo needed. */
  body:has(.ask-page) {
    background: #f4ece0 !important;
    color: #1a1a1a;
  }
</style>

<style>
  .ask-page {
    padding: 110px 6vw 80px;
    max-width: 760px;
    margin: 0 auto;
    color: #1a1a1a;
  }

  /* HEADER — tight, small Buddy + title */
  .ask-head {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 22px;
  }
  .ask-mascot-mini { flex-shrink: 0; }
  .ask-title-block { display: flex; flex-direction: column; }
  .ask-h1 {
    font-family: 'Georgia', serif;
    font-size: clamp(34pt, 5.6vw, 56pt);
    color: #1a1a1a;
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1;
    font-weight: 800;
  }
  .ask-bang {
    color: #c83a08;
    display: inline-block;
    transform: rotate(6deg);
    transform-origin: 50% 70%;
    margin-left: 2px;
  }
  .ask-buddy-tagline {
    font-family: 'Georgia', serif;
    font-style: italic;
    font-size: 13pt;
    color: #4a3a20;
    margin-top: 4px;
  }

  /* INPUT BLOCK — dominant */
  .ask-input-block {
    margin-bottom: 18px;
  }
  .ask-form {
    display: flex;
    gap: 8px;
    align-items: stretch;
  }
  .ask-input {
    flex: 1;
    height: 52px;
    background: #fffdf5;
    border: 1.5px solid #1a1a1a;
    border-radius: 10px;
    color: #1a1a1a;
    padding: 0 16px;
    font-family: 'Georgia', serif;
    font-size: 14pt;
    outline: none;
    transition: box-shadow 200ms, border-color 200ms;
  }
  .ask-input::placeholder { color: #9a8a6a; font-style: italic; }
  .ask-input:focus {
    border-color: #c83a08;
    box-shadow: 0 0 0 4px rgba(200, 58, 8, 0.12);
  }
  .ask-btn {
    background: #1a1a1a;
    color: #f0a500;
    border: 1.5px solid #1a1a1a;
    height: 52px;
    padding: 0 22px;
    border-radius: 10px;
    font-family: 'Courier New', monospace;
    font-size: 11pt;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 200ms, transform 150ms, box-shadow 200ms;
  }
  .ask-btn:hover:not(:disabled) {
    background: #2a2a2a;
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
  }
  .ask-btn:disabled { opacity: 0.55; cursor: progress; }

  /* STATUS */
  .ask-status {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
    font-family: 'Courier New', monospace;
    font-size: 10pt;
    color: #6a5a3a;
    letter-spacing: 0.04em;
  }
  .ask-status-dot {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #2bb673;
    box-shadow: 0 0 0 0 rgba(43, 182, 115, 0.6);
    animation: ask-pulse-online 2.4s ease-in-out infinite;
  }
  .ask-status[data-state="thinking"] .ask-status-dot {
    background: #f0a500;
    animation: ask-pulse-thinking 0.9s ease-in-out infinite;
  }
  @keyframes ask-pulse-online {
    0%, 100% { box-shadow: 0 0 0 0 rgba(43, 182, 115, 0.55); }
    50%      { box-shadow: 0 0 0 6px rgba(43, 182, 115, 0); }
  }
  @keyframes ask-pulse-thinking {
    0%, 100% { box-shadow: 0 0 0 0 rgba(240, 165, 0, 0.6); }
    50%      { box-shadow: 0 0 0 7px rgba(240, 165, 0, 0); }
  }

  /* RESPONSE */
  .ask-response {
    margin: 0 0 24px;
    padding: 0;
    color: #2a2418;
    font-family: 'Georgia', serif;
    font-size: 13pt;
    line-height: 1.6;
    min-height: 0;
    opacity: 0;
    transition: opacity 240ms;
  }
  .ask-response.visible { opacity: 1; }
  .ask-response.visible:not(.loading) {
    background: #fffdf5;
    border: 1px solid rgba(180, 138, 0, 0.22);
    border-radius: 10px;
    padding: 14px 18px;
  }
  .ask-thinking {
    display: inline-flex;
    align-items: baseline;
    gap: 2px;
    font-family: 'Courier New', monospace;
    font-size: 10.5pt;
    letter-spacing: 0.06em;
    color: #8a5a00;
  }

  /* PLANETS — secondary */
  .ask-planets {
    opacity: 0.88;
  }
  .ask-planet-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 8px;
    margin-bottom: 8px;
  }
  .ask-planet {
    font-family: 'Courier New', monospace;
    font-size: 9.5pt;
    color: rgba(60, 50, 30, 0.45);
    padding: 4px 10px;
    border-radius: 6px;
    border: 1px solid rgba(180, 138, 0, 0.13);
    background: rgba(255, 255, 255, 0.45);
    transition: color 220ms ease, background 220ms ease, border-color 220ms ease, transform 220ms ease;
  }
  .ask-planet { letter-spacing: 0.06em; }
  .ask-planet.on {
    color: #8a5a00;
    background: rgba(240, 165, 0, 0.16);
    border-color: rgba(180, 138, 0, 0.5);
    transform: translateY(-1px);
    text-shadow: 0 0 8px rgba(255, 220, 130, 0.5);
  }
  .ask-planets-anchor {
    text-align: center;
    font-family: 'Courier New', monospace;
    font-size: 9pt;
    color: #8a7a5a;
    letter-spacing: 0.08em;
    margin-top: 4px;
  }

  @media (max-width: 620px) {
    .ask-page { padding: 90px 5vw 60px; }
    .ask-head { gap: 12px; }
    .ask-mascot-mini :global(.buddy-mascot-canvas) { width: 76px !important; }
    .ask-input { font-size: 12pt; height: 48px; }
    .ask-btn { height: 48px; padding: 0 16px; font-size: 10pt; }
  }
</style>

</Layout>
