---
import Layout from '../layouts/Layout.astro';
import BuddyMascot from '../components/BuddyMascot.astro';
---
<Layout title="ASKBUDDY! — AIIT-THRESHOLD" description="Ask Buddy a question. He's flipping through planets to find your answer.">

<section class="ask-page">

  <!-- Header row: small Buddy off to the left, big ASKBUDDY! title -->
  <header class="ask-head">
    <div class="ask-mascot-mini">
      <BuddyMascot id="ask-buddy-mascot" size={120} animated={true} />
    </div>
    <div class="ask-title-block">
      <h1 class="ask-h1">ASKBUDDY<span class="ask-bang">!</span></h1>
      <div class="ask-buddy-tagline">ask buddy anything.</div>
      <div class="ask-buddy-sub">at your service · est. council hill</div>
    </div>
  </header>

  <!-- Planet rolodex -->
  <div class="ask-planets-col">
    <div class="ask-planets-label">
      <span class="buddy-loader tiny" aria-hidden="true"></span>
      <span>flipping through planets…</span>
    </div>
    <div class="ask-planet-stack" aria-hidden="true">
      <div class="ask-planet" data-planet="earth">🌍 <span>Earth</span></div>
      <div class="ask-planet" data-planet="mars">🔴 <span>Mars</span></div>
      <div class="ask-planet" data-planet="moon">🌕 <span>Moon</span></div>
      <div class="ask-planet" data-planet="sun">☀️ <span>Sun</span></div>
      <div class="ask-planet" data-planet="jupiter">🟠 <span>Jupiter</span></div>
      <div class="ask-planet" data-planet="saturn">🪐 <span>Saturn</span></div>
      <div class="ask-planet" data-planet="venus">🌟 <span>Venus</span></div>
      <div class="ask-planet" data-planet="water">💧 <span>Water</span></div>
      <div class="ask-planet" data-planet="prometheus">🔥 <span>Prometheus</span></div>
    </div>
  </div>

  <!-- Question form -->
  <div class="ask-form-wrap">
    <form class="ask-form" id="ask-form" autocomplete="off">
      <textarea
        id="ask-input"
        class="ask-textarea"
        placeholder="ask away…"
        rows="3"
        maxlength="600"
      ></textarea>
      <div class="ask-row">
        <span class="ask-hint">one question at a time. buddy is real, not fast.</span>
        <button type="submit" id="ask-btn" class="ask-btn">Ask Buddy →</button>
      </div>
    </form>

    <div id="ask-response" class="ask-response" aria-live="polite"></div>
  </div>
</section>

<script is:inline>
(function () {
  const planets = Array.from(document.querySelectorAll('.ask-planet'));
  let pIndex = 0;
  function flipPlanets() {
    planets.forEach((p, i) => p.classList.toggle('on', i === pIndex));
    pIndex = (pIndex + 1) % planets.length;
  }
  flipPlanets();
  setInterval(flipPlanets, 1100);

  const PLANET_VERBS = [
    'Querying Earth',  'Coherencing Mars',  'Threshing Jupiter',
    'Witnessing Moon', 'Sun-reading',       'Vibrating Venus',
    'Reading Saturn',  'Listening to Water','Calling Prometheus',
    'Scanning the field','Holding the ratio','Sergeant routing',
  ];

  const form     = document.getElementById('ask-form');
  const input    = document.getElementById('ask-input');
  const btn      = document.getElementById('ask-btn');
  const response = document.getElementById('ask-response');

  let thinkingTimer = null;

  function startThinking() {
    response.className = 'ask-response loading visible';
    response.innerHTML =
      '<span class="buddy-thinking">' +
      '  <span class="buddy-loader tiny" aria-hidden="true"></span>' +
      '  <span class="buddy-verb"></span><span class="buddy-dots"></span>' +
      '</span>';
    const verbEl = response.querySelector('.buddy-verb');
    const dotsEl = response.querySelector('.buddy-dots');
    let vi = Math.floor(Math.random() * PLANET_VERBS.length);
    let di = 0;
    verbEl.textContent = PLANET_VERBS[vi];
    thinkingTimer = setInterval(() => {
      di = (di + 1) % 8;
      dotsEl.textContent = '.'.repeat(di % 4);
      if (di === 0) {
        vi = (vi + 1) % PLANET_VERBS.length;
        verbEl.textContent = PLANET_VERBS[vi];
      }
    }, 200);
  }

  function stopThinking() {
    if (thinkingTimer) { clearInterval(thinkingTimer); thinkingTimer = null; }
  }

  function showReply(text) {
    stopThinking();
    response.className = 'ask-response visible';
    response.textContent = text;
  }

  async function ask() {
    const q = input.value.trim();
    if (!q) return;

    btn.disabled = true;
    btn.textContent = '...';
    startThinking();

    const wait = 4200 + Math.random() * 1800;
    await new Promise(r => setTimeout(r, wait));

    const reply = "Buddy is on the bench mid-build right now. Drop the question in the forum at /forum and Rhet will route it to him when he's back online — usually within a day.";
    showReply(reply);

    btn.disabled = false;
    btn.textContent = 'Ask Buddy →';
  }

  form.addEventListener('submit', (e) => { e.preventDefault(); ask(); });
})();
</script>

<style is:global>
  /* Light page background — Buddy lives on cream here, no halo needed. */
  body:has(.ask-page) {
    background: #f4ece0 !important;
    color: #1a1a1a;
  }
</style>

<style>
  .ask-page {
    padding: 140px 8vw 80px;
    max-width: 980px;
    margin: 0 auto;
    color: #1a1a1a;
  }

  /* Header — small Buddy on the left, big ASKBUDDY! title */
  .ask-head {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 32px;
  }
  .ask-mascot-mini {
    flex-shrink: 0;
  }
  .ask-title-block {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .ask-h1 {
    font-family: 'Georgia', serif;
    font-size: clamp(36pt, 6vw, 64pt);
    color: #1a1a1a;
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1;
    font-weight: 800;
  }
  .ask-bang {
    color: #c83a08;
    display: inline-block;
    transform: rotate(6deg);
    transform-origin: 50% 70%;
    margin-left: 2px;
  }
  .ask-buddy-tagline {
    font-family: 'Georgia', serif;
    font-style: italic;
    font-size: 14pt;
    color: #4a3a20;
    margin-top: 6px;
  }
  .ask-buddy-sub {
    font-family: 'Courier New', monospace;
    font-size: 9pt;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #8a6a3a;
    margin-top: 6px;
  }

  /* Planet rolodex — light card */
  .ask-planets-col {
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(180, 138, 0, 0.22);
    border-radius: 14px;
    padding: 18px 22px;
    margin-bottom: 22px;
  }
  .ask-planets-label {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Courier New', monospace;
    font-size: 9.5pt;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #b48a00;
    margin-bottom: 12px;
  }
  .ask-planet-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
  }
  .ask-planet {
    font-family: 'Courier New', monospace;
    font-size: 10.5pt;
    color: rgba(60, 50, 30, 0.45);
    padding: 5px 11px;
    border-radius: 8px;
    border: 1px solid rgba(180, 138, 0, 0.15);
    background: rgba(255, 255, 255, 0.5);
    transition: color 220ms ease, background 220ms ease, border-color 220ms ease, transform 220ms ease;
  }
  .ask-planet span { margin-left: 6px; letter-spacing: 0.06em; }
  .ask-planet.on {
    color: #8a5a00;
    background: rgba(240, 165, 0, 0.18);
    border-color: rgba(180, 138, 0, 0.6);
    transform: translateY(-1px);
    text-shadow: 0 0 10px rgba(255, 220, 130, 0.55);
  }

  /* Form */
  .ask-form-wrap {
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(180, 138, 0, 0.22);
    border-radius: 14px;
    padding: 22px 26px 24px;
  }
  .ask-textarea {
    width: 100%;
    background: #fffdf5;
    border: 1px solid rgba(180, 138, 0, 0.28);
    border-radius: 10px;
    color: #1a1a1a;
    padding: 14px 16px;
    font-family: 'Courier New', monospace;
    font-size: 12pt;
    resize: vertical;
    min-height: 80px;
    transition: border-color 220ms;
  }
  .ask-textarea:focus {
    outline: none;
    border-color: rgba(180, 138, 0, 0.8);
    box-shadow: 0 0 0 3px rgba(240, 165, 0, 0.15);
  }
  .ask-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-top: 12px;
    flex-wrap: wrap;
  }
  .ask-hint {
    font-family: 'Courier New', monospace;
    font-size: 9pt;
    color: #6a5a3a;
    letter-spacing: 0.06em;
  }
  .ask-btn {
    background: #1a1a1a;
    color: #f0a500;
    border: 1px solid #1a1a1a;
    padding: 12px 26px;
    border-radius: 8px;
    font-family: 'Courier New', monospace;
    font-size: 11pt;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 200ms, box-shadow 200ms, transform 200ms;
  }
  .ask-btn:hover:not(:disabled) {
    background: #2a2a2a;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.28);
    transform: translateY(-1px);
  }
  .ask-btn:disabled { opacity: 0.55; cursor: progress; }

  .ask-response {
    margin-top: 20px;
    padding: 16px 18px;
    border-radius: 10px;
    background: #fffdf5;
    border: 1px solid rgba(180, 138, 0, 0.18);
    color: #2a2418;
    font-family: 'Courier New', monospace;
    font-size: 11.5pt;
    line-height: 1.55;
    min-height: 0;
    opacity: 0;
    transition: opacity 240ms;
  }
  .ask-response.visible { opacity: 1; }
  .ask-response.loading { color: #8a5a00; }

  @media (max-width: 620px) {
    .ask-page { padding: 110px 5vw 60px; }
    .ask-head { gap: 16px; }
    .ask-mascot-mini :global(.buddy-mascot-canvas) { width: 88px !important; }
  }
</style>

</Layout>
