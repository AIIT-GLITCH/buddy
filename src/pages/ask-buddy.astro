---
import Layout from '../layouts/Layout.astro';
import BuddyMascot from '../components/BuddyMascot.astro';
---
<Layout title="ASKBUDDY! — AIIT-THRESHOLD" description="Ask Buddy anything. He thinks by flipping through planets.">

<section class="ask-page">

  <!-- Header: small Buddy + title (tight) -->
  <header class="ask-head">
    <div class="ask-mascot-mini">
      <BuddyMascot id="ask-buddy-mascot" size={104} animated={true} />
    </div>
    <div class="ask-title-block">
      <h1 class="ask-h1">ASKBUDDY<span class="ask-bang">!</span></h1>
      <div class="ask-buddy-tagline">ask buddy anything.</div>
    </div>
  </header>

  <!-- INPUT BLOCK — top 35%, dominant -->
  <div class="ask-input-block">
    <form class="ask-form" id="ask-form" autocomplete="off">
      <input
        id="ask-input"
        class="ask-input"
        type="text"
        placeholder="Ask Buddy anything..."
        maxlength="600"
      />
      <button type="submit" id="ask-btn" class="ask-btn">Ask →</button>
    </form>
    <a href="/#hero-joke-anchor" class="ask-joke-link">or tell buddy a joke.</a>
    <div class="ask-status" id="ask-status">
      <span class="ask-status-dot" id="ask-status-dot"></span>
      <span class="ask-status-text" id="ask-status-text">buddy online</span>
    </div>
    <!-- Dev-only local-API panel. Hidden by default; reveal with ?dev=1 -->
    <div class="ask-local-panel" id="ask-local-panel" hidden style="display:none">
      <input id="ask-local-api" class="ask-local-input" type="url" autocomplete="off" spellcheck="false" value="http://localhost:8585" aria-label="Buddy API URL" />
      <input id="ask-local-token" class="ask-local-input token" type="password" autocomplete="off" spellcheck="false" placeholder="local token" aria-label="Buddy API token" />
      <button type="button" id="ask-local-save" class="ask-local-btn">Connect</button>
      <a id="ask-local-console" class="ask-local-console" href="http://localhost:8585/app" target="_blank" rel="noopener noreferrer">Console</a>
    </div>
    <script is:inline>
      (function () {
        try {
          const params = new URLSearchParams(window.location.search);
          if (params.get('dev') === '1') {
            const panel = document.getElementById('ask-local-panel');
            if (panel) { panel.hidden = false; panel.style.display = ''; }
          }
        } catch (_) {}
      })();
    </script>
  </div>

  <!-- Response slot -->
  <div id="ask-response" class="ask-response" aria-live="polite"></div>

  <!-- PLANETS — secondary, "visible cognition" -->
  <div class="ask-planets" id="ask-planets">
    <div class="ask-planet-stack" aria-hidden="true">
      <div class="ask-planet" data-planet="mercury">Mercury</div>
      <div class="ask-planet" data-planet="venus">Venus</div>
      <div class="ask-planet" data-planet="earth">Earth</div>
      <div class="ask-planet" data-planet="mars">Mars</div>
      <div class="ask-planet" data-planet="jupiter">Jupiter</div>
      <div class="ask-planet" data-planet="saturn">Saturn</div>
      <div class="ask-planet" data-planet="uranus">Uranus</div>
      <div class="ask-planet" data-planet="neptune">Neptune</div>
    </div>
    <div class="ask-planets-anchor">buddy thinks by flipping through planets</div>
  </div>

</section>

<script is:inline>
(function () {
  if (location.hash === '#ask') {
    const i = document.getElementById('ask-input');
    if (i) { i.focus({ preventScroll: false }); }
  }
  const planets = Array.from(document.querySelectorAll('.ask-planet'));
  const planetsWrap = document.getElementById('ask-planets');
  let pIndex = 0;
  let flipMs = 1100; // idle cadence
  let flipTimer = null;
  function flipPlanets() {
    planets.forEach((p, i) => p.classList.toggle('on', i === pIndex));
    pIndex = (pIndex + 1) % planets.length;
  }
  function startFlip() {
    flipPlanets();
    if (flipTimer) clearInterval(flipTimer);
    flipTimer = setInterval(flipPlanets, flipMs);
  }
  function setFlipSpeed(ms) { flipMs = ms; startFlip(); }
  startFlip();

  const PLANET_VERBS = [
    'querying mercury', 'vibrating venus',   'querying earth',
    'coherencing mars', 'threshing jupiter', 'reading saturn',
    'tilting uranus',   'soundproofing neptune',
    'scanning the field','holding the ratio','sergeant routing',
  ];

  const form     = document.getElementById('ask-form');
  const input    = document.getElementById('ask-input');
  const btn      = document.getElementById('ask-btn');
  const response = document.getElementById('ask-response');
  const statusDot = document.getElementById('ask-status-dot');
  const statusText = document.getElementById('ask-status-text');
  const statusBlk  = document.getElementById('ask-status');
  const localApiInput = document.getElementById('ask-local-api');
  const localTokenInput = document.getElementById('ask-local-token');
  const localSaveBtn = document.getElementById('ask-local-save');
  const localConsole = document.getElementById('ask-local-console');

  let thinkingTimer = null;

  const LOCAL_API_KEY = 'askbuddy_local_api';
  const LOCAL_TOKEN_KEY = 'askbuddy_local_token';
  const LOCAL_SESSION_KEY = 'askbuddy_local_session';

  function normalizeApi(url) {
    return String(url || '').replace(/\/+$/, '');
  }

  function getLocalApi() {
    try { return normalizeApi(localStorage.getItem(LOCAL_API_KEY) || localApiInput.value || 'http://localhost:8585'); }
    catch { return 'http://localhost:8585'; }
  }

  function getLocalToken() {
    try { return localStorage.getItem(LOCAL_TOKEN_KEY) || ''; }
    catch { return ''; }
  }

  function setLocalConfig(api, token) {
    const cleanApi = normalizeApi(api || 'http://localhost:8585');
    try {
      localStorage.setItem(LOCAL_API_KEY, cleanApi);
      if (token) localStorage.setItem(LOCAL_TOKEN_KEY, token);
    } catch {}
    localApiInput.value = cleanApi;
    localConsole.href = cleanApi + '/app';
    if (token) localTokenInput.value = token;
    setStatus(token ? 'online' : 'surface', token ? 'real buddy local' : 'surface buddy');
  }

  (function captureLocalConfig(){
    try {
      const p = new URLSearchParams(location.search);
      const api = p.get('buddy_api') || localStorage.getItem(LOCAL_API_KEY) || 'http://localhost:8585';
      const token = p.get('buddy_token') || localStorage.getItem(LOCAL_TOKEN_KEY) || '';
      setLocalConfig(api, token);
    } catch {
      setLocalConfig('http://localhost:8585', '');
    }
  })();

  localSaveBtn.addEventListener('click', () => {
    setLocalConfig(localApiInput.value, localTokenInput.value.trim());
  });

  function setStatus(state, label) {
    statusBlk.dataset.state = state; // online | thinking | done
    statusText.textContent = label;
  }

  function startThinking() {
    setStatus('thinking', 'buddy thinking');
    setFlipSpeed(380); // planets speed up

    // proof of life within ~150ms
    response.className = 'ask-response loading visible';
    response.innerHTML =
      '<span class="ask-thinking">' +
      '  <span class="ask-thinking-verb"></span><span class="ask-thinking-dots"></span>' +
      '</span>';
    const verbEl = response.querySelector('.ask-thinking-verb');
    const dotsEl = response.querySelector('.ask-thinking-dots');
    let vi = Math.floor(Math.random() * PLANET_VERBS.length);
    let di = 0;
    verbEl.textContent = PLANET_VERBS[vi];
    thinkingTimer = setInterval(() => {
      di = (di + 1) % 8;
      dotsEl.textContent = '.'.repeat(di % 4);
      if (di === 0) {
        vi = (vi + 1) % PLANET_VERBS.length;
        verbEl.textContent = PLANET_VERBS[vi];
      }
    }, 200);
  }

  function stopThinking() {
    if (thinkingTimer) { clearInterval(thinkingTimer); thinkingTimer = null; }
    setFlipSpeed(1100);
  }

  function escHtml(s) {
    return String(s).replace(/[&<>"']/g, c => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[c]));
  }

  function wireShare(root) {
    const btn = root.querySelector('.fo-share-v2');
    const tray = root.querySelector('.fo-share-tray');
    if (!btn || !tray) return;

    const answer = btn.getAttribute('data-answer') || '';
    const pageUrl = location.origin + location.pathname;
    const excerpt = answer.length > 180 ? answer.slice(0, 177) + '…' : answer;
    const shareText = `buddy:\n${answer}\n\naiit-threshold.com`;
    const emailBody = `buddy:\n${answer}\n\naiit-threshold.com`;

    const setExpanded = (open) => {
      tray.hidden = !open;
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    };
    btn.setAttribute('aria-expanded', 'false');
    btn.setAttribute('aria-haspopup', 'true');

    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      try {
        if (navigator.share) {
          await navigator.share({ text: shareText, url: pageUrl });
          return;
        }
      } catch { /* cancel or unsupported -> fall through */ }
      setExpanded(tray.hidden);
    });

    document.addEventListener('click', (e) => {
      if (tray.hidden) return;
      if (tray.contains(e.target) || btn.contains(e.target)) return;
      setExpanded(false);
    });

    const flash = (el, msg, ok = true) => {
      const labelEl = el.querySelector('.fo-share-txt') || el;
      const orig = labelEl.textContent;
      labelEl.textContent = msg;
      if (ok) el.classList.add('copied');
      setTimeout(() => {
        labelEl.textContent = orig;
        el.classList.remove('copied');
      }, 1400);
    };

    tray.querySelectorAll('[data-share]').forEach(item => {
      item.addEventListener('click', async (e) => {
        e.stopPropagation();
        const kind = item.getAttribute('data-share');
        try {
          if (kind === 'copy-link') {
            await navigator.clipboard.writeText(pageUrl);
            flash(item, 'Copied ✓');
          } else if (kind === 'copy-answer') {
            await navigator.clipboard.writeText(shareText);
            flash(item, 'Copied ✓');
          } else if (kind === 'facebook') {
            window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(pageUrl), '_blank', 'noopener,noreferrer');
          } else if (kind === 'x') {
            const t = 'buddy: ' + excerpt;
            window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent(t) + '&url=' + encodeURIComponent(pageUrl), '_blank', 'noopener,noreferrer');
          } else if (kind === 'reddit') {
            window.open('https://www.reddit.com/submit?url=' + encodeURIComponent(pageUrl) + '&title=' + encodeURIComponent('buddy: ' + excerpt), '_blank', 'noopener,noreferrer');
          } else if (kind === 'email') {
            location.href = 'mailto:?subject=' + encodeURIComponent('Buddy') + '&body=' + encodeURIComponent(emailBody);
          }
        } catch {
          flash(item, 'failed', false);
        }
      });
    });
  }

  function showReply(text) {
    stopThinking();
    setStatus('online', 'buddy online');
    response.className = 'ask-response visible';
    response.textContent = text;
  }

	  function showFirstOutput(payload) {
	    stopThinking();
	    setStatus('online', 'buddy online');
	    const answer = payload.answer || '';
    const obs = payload.observation || '';
    const cta = payload.cta || 'Pass it on';
    const strong = payload.observation_kind === 'substrate';
    const showBreadcrumb = strong && Math.random() < 0.08;

    let html = '<div class="fo-block">';
    html += '<div class="fo-buddy">buddy:</div>';
    html += `<div class="fo-answer">${escHtml(answer)}</div>`;
    if (obs) {
      html += '<div class="fo-sep">…</div>';
      html += `<div class="fo-obs">${escHtml(obs)}</div>`;
    }
    if (showBreadcrumb) {
      html += '<div class="fo-substrate">this is the surface.<br>the deeper system is still being built.</div>';
    }
    html += '<div class="fo-actions">';
    html += '<div class="fo-actionbar">';
    html += `<button type="button" class="fo-share-v2" data-answer="${escHtml(answer)}" aria-label="Pass it on">`;
    html += '<svg class="fo-share-ico" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">';
    html += '<path d="M12 3v12"/><path d="m7 8 5-5 5 5"/><path d="M5 14v5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5"/>';
    html += '</svg>';
    html += `<span>${escHtml(cta)}</span>`;
    html += '</button>';
    html += '<a class="fo-gary" href="/gary">Think this holds up? →</a>';
    html += '</div>';
    html += '<div class="fo-share-tray" hidden role="menu">';
    html += '<div class="fo-share-row fo-share-copy">';
    html += '<button type="button" class="fo-share-item" data-share="copy-link" aria-label="Copy link">';
    html += '<svg class="fo-share-item-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 14a5 5 0 0 1 0-7l3-3a5 5 0 0 1 7 7l-1.5 1.5"/><path d="M14 10a5 5 0 0 1 0 7l-3 3a5 5 0 0 1-7-7l1.5-1.5"/></svg>';
    html += '<span class="fo-share-txt">Copy link</span>';
    html += '</button>';
    html += '<button type="button" class="fo-share-item" data-share="copy-answer" aria-label="Copy answer">';
    html += '<svg class="fo-share-item-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h8"/></svg>';
    html += '<span class="fo-share-txt">Copy answer</span>';
    html += '</button>';
    html += '</div>';
    html += '<div class="fo-share-div" aria-hidden="true"></div>';
    html += '<div class="fo-share-row fo-share-social">';
    html += '<button type="button" class="fo-share-item" data-share="facebook" aria-label="Share to Facebook">';
    html += '<svg class="fo-share-item-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M13 9h2V7h-2a2 2 0 0 0-2 2v2H9v2h2v4h2v-4h2v-2h-2V9z"/></svg>';
    html += '<span class="fo-share-txt">Facebook</span>';
    html += '</button>';
    html += '<button type="button" class="fo-share-item" data-share="x" aria-label="Share to X">';
    html += '<svg class="fo-share-item-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 5l14 14M19 5 5 19"/></svg>';
    html += '<span class="fo-share-txt">X</span>';
    html += '</button>';
    html += '<button type="button" class="fo-share-item" data-share="reddit" aria-label="Share to Reddit">';
    html += '<svg class="fo-share-item-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="13" r="8"/><circle cx="9.2" cy="12.5" r="1" fill="currentColor" stroke="none"/><circle cx="14.8" cy="12.5" r="1" fill="currentColor" stroke="none"/><path d="M9 16c.9.8 1.9 1.2 3 1.2s2.1-.4 3-1.2"/><path d="M12 5V3"/></svg>';
    html += '<span class="fo-share-txt">Reddit</span>';
    html += '</button>';
    html += '<button type="button" class="fo-share-item" data-share="email" aria-label="Send via email">';
    html += '<svg class="fo-share-item-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>';
    html += '<span class="fo-share-txt">Email</span>';
    html += '</button>';
    html += '</div>';
    html += '</div>';
    html += '</div>';
    if (strong) {
      html += '<a class="fo-what" href="/manifesto">what is this →</a>';
    }
    html += '</div>';

    response.className = 'ask-response visible';
	    response.innerHTML = html;
	    wireShare(response);
	  }

	  function pendingMessage(attempt, networkIssue = false) {
	    const elapsed = Math.max(0, attempt) * PENDING_POLL_MS;
	    if (networkIssue) return 'connection hiccup — buddy still has your question. retrying…';
	    if (elapsed < 15000) return 'buddy got your question, hang tight…';
	    if (elapsed < 30000) return 'buddy is still working — your question is saved.';
	    if (elapsed < 60000) return 'this is taking longer than usual — no need to resend.';
	    if (elapsed < 120000) return 'buddy is still holding it. full-memory answers can take a minute.';
	    if (elapsed < 240000) return 'still saved, still checking. keep this tab open.';
	    return 'last stretch before the five-minute hold expires — still checking.';
	  }

	  function updatePendingMessage(attempt, networkIssue = false) {
	    const pending = response.querySelector('.fo-pending');
	    if (pending) pending.textContent = pendingMessage(attempt, networkIssue);
	  }

	  function showPending(question, attempt = 0) {
	    stopThinking();
	    setStatus('thinking', 'buddy holding question');
	    setFlipSpeed(520);
	    response.className = 'ask-response visible';
	    response.innerHTML =
	      '<div class="fo-block">' +
	      '<div class="fo-buddy">you:</div>' +
	      `<div class="fo-answer">${escHtml(question || '')}</div>` +
	      '<div class="fo-sep">…</div>' +
	      `<div class="fo-obs fo-pending">${escHtml(pendingMessage(attempt))}</div>` +
	      '</div>';
	  }

  // Dev bypass: visiting /?dev=X or /ask-buddy?dev=X stores token; sent with every request.
  const DEV_KEY = 'buddy_dev_bypass';
  (function captureDev(){
    try {
      const p = new URLSearchParams(location.search).get('dev');
      if (p) {
        localStorage.setItem(DEV_KEY, p);
        // drop localStorage joke lock too so tester gets a clean slate
        localStorage.removeItem('buddy_joke_used');
      }
    } catch (e) {}
  })();
  function getDevBypass() {
    try { return localStorage.getItem(DEV_KEY) || ''; } catch (e) { return ''; }
  }

  const FP_STORAGE = 'askbuddy_fp';
  function getFingerprint() {
    try {
      let fp = localStorage.getItem(FP_STORAGE);
      if (!fp) {
        fp = crypto.randomUUID ? crypto.randomUUID() :
          (Date.now().toString(36) + Math.random().toString(36).slice(2));
        localStorage.setItem(FP_STORAGE, fp);
      }
      return fp;
    } catch (e) {
      return 'session-' + Math.random().toString(36).slice(2);
    }
  }

  const SESSION_STORAGE = 'askbuddy_session';
  function getSessionId() {
    try {
      let sid = localStorage.getItem(SESSION_STORAGE);
      if (!sid) {
        sid = crypto.randomUUID ? crypto.randomUUID() :
          (Date.now().toString(36) + Math.random().toString(36).slice(2));
        localStorage.setItem(SESSION_STORAGE, sid);
      }
      return sid;
    } catch (e) {
      return 'sess-' + Math.random().toString(36).slice(2);
    }
  }

	  const MAX_HISTORY_PAIRS = 6;
	  const turnHistory = [];
	  function pushTurn(q, a) {
	    turnHistory.push({ q, a });
	    while (turnHistory.length > MAX_HISTORY_PAIRS) turnHistory.shift();
	  }

	  const PENDING_STORAGE = 'askbuddy_pending_requests';
	  const PENDING_POLL_MS = 3000;
	  const PENDING_MAX_POLLS = 100;
	  function loadPending() {
	    try {
	      const rows = JSON.parse(localStorage.getItem(PENDING_STORAGE) || '[]');
	      return Array.isArray(rows) ? rows.filter(row => row && row.request_id) : [];
	    } catch {
	      return [];
	    }
	  }
	  function savePending(rows) {
	    try { localStorage.setItem(PENDING_STORAGE, JSON.stringify(rows.slice(-3))); } catch {}
	  }
	  function addPending(entry) {
	    const rows = loadPending().filter(row => row.request_id !== entry.request_id);
	    rows.push(entry);
	    savePending(rows);
	  }
	  function removePending(requestId) {
	    savePending(loadPending().filter(row => row.request_id !== requestId));
	  }
	  function recoverPending() {
	    const now = Date.now();
	    const rows = loadPending().filter(row => now - Number(row.ts || 0) < 5 * 60 * 1000);
	    savePending(rows);
	    if (!rows.length) return;
	    const attempt = Math.floor((now - Number(rows[0].ts || now)) / PENDING_POLL_MS);
	    showPending(rows[0].question || 'pending question', attempt);
	    rows.forEach(row => {
	      const rowAttempt = Math.floor((now - Number(row.ts || now)) / PENDING_POLL_MS);
	      pollPending(row, rowAttempt);
	    });
	  }
	  async function pollPending(entry, attempt) {
	    if (!entry || !entry.request_id) return;
	    let payload = null;
	    try {
	      const res = await fetch('/api/askbuddy_poll', {
	        method: 'POST',
	        headers: { 'content-type': 'application/json' },
	        body: JSON.stringify({
	          request_id: entry.request_id,
	          session_id: entry.session_id,
	        }),
	      });
	      payload = await res.json();
	    } catch {
	      payload = { ok: false, error: 'network_failed' };
	    }

	    if (payload && payload.ok && payload.status === 'ready') {
	      removePending(entry.request_id);
	      pushTurn(entry.question || '', payload.answer || '');
	      showFirstOutput(payload);
	      return;
	    }
	    if (payload && payload.ok && payload.status === 'pending') {
	      updatePendingMessage(attempt);
	      if (attempt < PENDING_MAX_POLLS) {
	        setTimeout(() => pollPending(entry, attempt + 1), PENDING_POLL_MS);
	      } else {
	        removePending(entry.request_id);
	        showReply('buddy was holding this but it timed out. send it again whenever.');
	      }
	      return;
	    }

	    if (payload && (payload.error === 'expired' || payload.status === 'expired')) {
	      removePending(entry.request_id);
	      showReply('buddy was holding this but it timed out. send it again whenever.');
	      return;
	    }

	    if (attempt < PENDING_MAX_POLLS) {
	      updatePendingMessage(attempt, payload && payload.error === 'network_failed');
	      setTimeout(() => pollPending(entry, attempt + 1), PENDING_POLL_MS);
	    } else {
	      removePending(entry.request_id);
	      showReply('buddy was holding this but it timed out. send it again whenever.');
	    }
	  }

	  async function localFetch(path, opts = {}) {
    const token = getLocalToken();
    const headers = Object.assign({}, opts.headers || {}, {
      'content-type': 'application/json',
      'authorization': 'Bearer ' + token,
    });
    const res = await fetch(getLocalApi() + path, Object.assign({}, opts, { headers }));
    const payload = await res.json().catch(() => ({}));
    if (!res.ok) {
      const err = new Error(payload.detail || payload.error || ('HTTP ' + res.status));
      err.status = res.status;
      throw err;
    }
    return payload;
  }

  async function ensureLocalSession() {
    let sid = '';
    try { sid = localStorage.getItem(LOCAL_SESSION_KEY) || ''; } catch {}
    if (sid) return sid;
    const created = await localFetch('/api/session/create', {
      method: 'POST',
      body: JSON.stringify({ mode: 'text' }),
    });
    sid = created.session_id;
    try { localStorage.setItem(LOCAL_SESSION_KEY, sid); } catch {}
    return sid;
  }

  async function askLocalBuddy(q) {
    if (!getLocalToken()) return null;
    let sid = await ensureLocalSession();
    try {
      const data = await localFetch('/api/chat', {
        method: 'POST',
        body: JSON.stringify({
          session_id: sid,
          message: q,
          max_tokens: 512,
          temperature: 0.35,
        }),
      });
      return {
        ok: true,
        layer: 'substrate',
        answer: data.response || '',
        observation: 'Saved to Buddy local session and Kokoro raw turns.',
        observation_kind: 'substrate',
        cta: 'Pass it on',
      };
    } catch (err) {
      if (err.status === 404) {
        try { localStorage.removeItem(LOCAL_SESSION_KEY); } catch {}
        sid = await ensureLocalSession();
        const data = await localFetch('/api/chat', {
          method: 'POST',
          body: JSON.stringify({ session_id: sid, message: q, max_tokens: 512, temperature: 0.35 }),
        });
        return {
          ok: true,
          layer: 'substrate',
          answer: data.response || '',
          observation: 'Saved to Buddy local session and Kokoro raw turns.',
          observation_kind: 'substrate',
          cta: 'Pass it on',
        };
      }
      return { ok: false, error: 'local_buddy_failed', detail: err.message };
    }
  }

  async function ask() {
    const q = input.value.trim();
    if (!q) return;
    btn.disabled = true;
    btn.textContent = '...';

    requestAnimationFrame(startThinking);

    const minShowMs = 1200;
    const t0 = performance.now();
    let payload = null;
    try {
      payload = await askLocalBuddy(q);
      if (!payload) {
        const res = await fetch('/api/askbuddy', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            question: q,
            fingerprint: getFingerprint(),
            session_id: getSessionId(),
            history: turnHistory.slice(),
            admin: getDevBypass(),
          }),
        });
        payload = await res.json();
      }
    } catch (e) {
      payload = { ok: false, error: 'network_failed' };
    }

    const elapsed = performance.now() - t0;
    if (elapsed < minShowMs) {
      await new Promise(r => setTimeout(r, minShowMs - elapsed));
    }

	    if (payload && payload.ok && payload.status === 'pending') {
	      const entry = {
	        request_id: payload.request_id,
	        session_id: getSessionId(),
	        question: q,
	        ts: Date.now(),
	      };
	      addPending(entry);
	      showPending(q);
	      input.value = '';
	      pollPending(entry, 0);
	    } else if (payload && payload.ok) {
	      pushTurn(q, payload.answer || '');
	      showFirstOutput(payload);
	      input.value = '';
	    } else if (payload && payload.error === 'daily_limit_reached') {
	      showReply(payload.message || "you've used today's question. come back tomorrow.");
	    } else if (payload && payload.error === 'budget_exhausted') {
	      showReply(payload.message || 'askbuddy is resting right now. check back later.');
	    } else if (payload && payload.message) {
	      showReply(payload.message);
	    } else {
	      const detail = (payload && payload.detail) ? ' — ' + payload.detail : '';
	      showReply('buddy tripped' + detail + '. try again in a minute.');
	    }

    btn.disabled = false;
    btn.textContent = 'Ask →';
  }

  form.addEventListener('submit', (e) => { e.preventDefault(); ask(); });
	  input.addEventListener('focus', () => setFlipSpeed(800));
	  input.addEventListener('blur',  () => { if (statusBlk.dataset.state !== 'thinking') setFlipSpeed(1100); });
	  recoverPending();

	  (function hydrateInitialQuestion(){
    try {
      const params = new URLSearchParams(location.search);
      const initial = (params.get('q') || params.get('question') || '').trim().slice(0, 600);
      if (!initial) return;

      input.value = initial;
      input.focus({ preventScroll: false });

      if (params.get('auto') === '1') {
        params.delete('q');
        params.delete('question');
        params.delete('auto');
        const qs = params.toString();
        history.replaceState(null, '', location.pathname + (qs ? '?' + qs : '') + '#ask');
        setTimeout(() => ask(), 120);
      }
    } catch {}
  })();
})();
</script>

