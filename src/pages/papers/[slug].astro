---
import Layout from '../../layouts/Layout.astro';
import papers from '../../data/papers.json';
import { tierForSlug } from '../../lib/paperTier.js';

export async function getStaticPaths() {
  const all = papers as any[];
  return all.map(p => ({
    params: { slug: p.slug },
    props:  { paper: p, all },
  }));
}

const { paper, all } = Astro.props;

// Related = same tag, nearest paper numbers, excluding self
const related = (all as any[])
  .filter(p => p.slug !== paper.slug && p.tag === paper.tag)
  .sort((a, b) => Math.abs(parseInt(a.num) - parseInt(paper.num)) - Math.abs(parseInt(b.num) - parseInt(paper.num)))
  .slice(0, 4);

const pdfUrl = `/papers/${paper.filename}`;

// Optional schema fields — render only if present in papers.json
const abstract       = paper.abstract       || '';
const coreClaim      = paper.core_claim     || '';
const keyEquation    = paper.key_equation   || '';
const plainEnglish   = paper.plain_english  || '';
const status         = paper.status         || '';
const keyNumbers     = (paper.key_numbers as Record<string,string>) || {};
const connectedPages = (paper.connected_domain_pages as string[]) || [];

const pageTitle = `Paper ${parseInt(paper.num)}${paper.suffix} · ${paper.title} · AIIT-THRESI`;
const pageDescription = coreClaim || abstract.slice(0, 200) || `${paper.title} — ${paper.tag} domain · AIIT-THRESI`;
const tier = tierForSlug(paper.slug);
---
<Layout title={pageTitle} description={pageDescription}>
  <div class="paper-page">
    <a class="back" href="/papers">← All Papers</a>

    <div class="paper-unlocked-line" id="paper-unlocked-line" data-slug={paper.slug} hidden>
      <span class="pul-spark">✦</span> unlocked via <a href="/trivia">Answer the Giants</a>
      <span class="pul-earned">— you earned this</span>
    </div>

    <div class="paper-head-num">Paper {parseInt(paper.num)}{paper.suffix}</div>
    <h1>{paper.title}</h1>
    <div class="paper-head-tag">
      {paper.tag}
      {status && <span class="paper-status" data-status={status.toLowerCase()}> · {status}</span>}
      <span class={`paper-tier-badge tier-${tier.key}`}>[{tier.label}]</span>
    </div>

    {coreClaim && (
      <div class="paper-claim" data-field="core_claim">
        <div class="paper-claim-label">Core claim</div>
        <div class="paper-claim-body">{coreClaim}</div>
      </div>
    )}

    {abstract && (
      <div class="paper-abstract" data-field="abstract">
        <div class="paper-section-label">Abstract</div>
        <div class="paper-section-body">{abstract}</div>
      </div>
    )}

    {keyEquation && (
      <div class="paper-equation" data-field="key_equation">
        <div class="paper-section-label">Key equation</div>
        <code class="paper-equation-body">{keyEquation}</code>
      </div>
    )}

    {plainEnglish && (
      <div class="paper-plain" data-field="plain_english">
        <div class="paper-section-label">In plain english</div>
        <div class="paper-section-body">{plainEnglish}</div>
      </div>
    )}

    {Object.keys(keyNumbers).length > 0 && (
      <div class="paper-numbers" data-field="key_numbers">
        <div class="paper-section-label">Key numbers</div>
        <ul class="paper-numbers-list">
          {Object.entries(keyNumbers).map(([k, v]) => (
            <li><span data-stat={k}><strong>{k}:</strong> {v}</span></li>
          ))}
        </ul>
      </div>
    )}

    {connectedPages.length > 0 && (
      <div class="paper-connected" data-field="connected_domain_pages">
        <div class="paper-section-label">See also</div>
        <ul class="paper-connected-list">
          {connectedPages.map(href => (
            <li><a href={href}>{href}</a></li>
          ))}
        </ul>
      </div>
    )}

    <div class="paper-meta">
      <div><div class="k">Author</div><div class="v">Rhet Dillard Wike</div></div>
      <div><div class="k">Domain</div><div class="v">{paper.tag}</div></div>
      <div><div class="k">Source</div><div class="v">{paper.filename}</div></div>
      <div><div class="k">Print Status</div><div class="v">wAIste Not · Verified</div></div>
    </div>

    <div class="paper-actions">
      <a class="btn" href={pdfUrl} target="_blank" rel="noopener">Open PDF</a>
      <a class="btn ghost" href={pdfUrl} download>Download</a>
    </div>

    <div class="paper-embed-wrap">
      <iframe class="paper-embed" src={pdfUrl} title={paper.title}></iframe>
    </div>

    {related.length > 0 && (
      <div class="related">
        <h3>Related in {paper.tag}</h3>
        <div class="papers-grid">
          {related.map(p => (
            <a class="paper-card" href={`/papers/${p.slug}`}>
              <div class="paper-num">Paper {parseInt(p.num)}{p.suffix}</div>
              <div class="paper-title">{p.title}</div>
              <div class="paper-tag">{p.tag}</div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div style="margin-top: 80px; padding-top: 40px; border-top: 1px solid var(--edge); font-family: 'Courier New', monospace; font-size: 9pt; letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted);">
      © 2026 Rhet Dillard Wike · AIIT-THRESHOLD LLC · All rights reserved
    </div>
  </div>
</Layout>

<script is:inline>
  (function () {
    const el = document.getElementById('paper-unlocked-line');
    if (!el) return;
    try {
      const slug = el.getAttribute('data-slug');
      const raw = localStorage.getItem('trivia_collected_slugs') || '[]';
      const set = new Set(JSON.parse(raw));
      if (slug && set.has(slug)) el.hidden = false;
    } catch (e) {}
  })();
</script>

<style>
  .paper-unlocked-line {
    margin: 14px 0 22px;
    font-family: 'Courier New', monospace;
    font-size: 0.78em;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #b48a00;
  }
  .paper-unlocked-line a {
    color: #D4AF37;
    text-decoration: none;
    border-bottom: 1px solid rgba(212,175,55,0.35);
    padding-bottom: 1px;
  }
  .paper-unlocked-line .pul-spark {
    color: #ffd166;
    margin-right: 6px;
  }
  .paper-unlocked-line .pul-earned {
    margin-left: 8px;
    color: #888;
    font-size: 0.9em;
    letter-spacing: 1.5px;
  }

  .paper-tier-badge {
    margin-left: 10px;
    font-family: 'Courier New', monospace;
    font-size: 0.78em;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .paper-tier-badge.tier-common   { color: #888888; }
  .paper-tier-badge.tier-rare     { color: #38bdf8; }
  .paper-tier-badge.tier-exotic   { color: #a78bfa; }
  .paper-tier-badge.tier-keystone { color: #ffd166; text-shadow: 0 0 8px rgba(255,209,102,0.4); }

  .paper-status {
    font-size: 0.75em;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 2px 8px;
    margin-left: 6px;
    border-radius: 4px;
    background: rgba(180, 138, 0, 0.15);
    color: #b48a00;
  }
  .paper-status[data-status="verified"] { background: rgba(64, 192, 176, 0.15); color: var(--teal, #40c0b0); }
  .paper-status[data-status="filed"]    { background: rgba(232, 88, 42, 0.15); color: #e8582a; }

  .paper-claim {
    margin: 28px 0;
    padding: 18px 22px;
    border-left: 3px solid #e8582a;
    background: rgba(232, 88, 42, 0.04);
  }
  .paper-claim-label {
    font-family: 'Courier New', monospace;
    font-size: 9pt;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #e8582a;
    margin-bottom: 6px;
  }
  .paper-claim-body { font-size: 1.05rem; line-height: 1.6; color: var(--ink); }

  .paper-abstract, .paper-equation, .paper-plain, .paper-numbers, .paper-connected {
    margin: 22px 0;
  }
  .paper-section-label {
    font-family: 'Courier New', monospace;
    font-size: 9pt;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 6px;
  }
  .paper-section-body { line-height: 1.65; color: var(--ink); }
  .paper-equation-body {
    display: inline-block;
    padding: 8px 14px;
    background: rgba(0, 0, 0, 0.04);
    border-radius: 4px;
    font-family: 'Courier New', monospace;
    font-size: 1rem;
  }
  .paper-numbers-list, .paper-connected-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .paper-numbers-list li, .paper-connected-list li {
    padding: 4px 0;
    font-family: 'Courier New', monospace;
    font-size: 0.95rem;
  }
  .paper-connected-list a { color: var(--teal, #40c0b0); text-decoration: none; }
  .paper-connected-list a:hover { text-decoration: underline; }
</style>
