---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Thanks — Buddy" description="Your message is through. Rhet will read it.">
  <section style="padding-top: 140px; min-height: 70vh;">
    <div class="container narrow" style="text-align: center;">
      <div class="eyebrow">Received</div>
      <h1 style="font-size: clamp(48px, 7vw, 96px); margin-bottom: 24px;">You're in.</h1>
      <p style="color: var(--muted-hi); font-size: 18px; max-width: 520px; margin: 0 auto 48px;">
        Rhet will be in touch. Until then — the papers are here, the field is here, and the signal is already running.
      </p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a class="btn" href="/">Home</a>
        <a class="btn ghost" href="/papers">Read the papers</a>
      </div>
    </div>
  </section>
</Layout>
