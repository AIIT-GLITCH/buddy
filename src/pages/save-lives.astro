---
import Layout from '../layouts/Layout.astro';
import Interlink from '../components/Interlink.astro';
import ReturnToBuddy from '../components/ReturnToBuddy.astro';
import { Content } from '../content/save-lives-now.md';
---
<Layout title="Save Lives Now — AIIT-THRESI" description="500+ pages. 284 research papers. Every intervention that can save lives today — with what already exists. Every citation verified.">

<section class="longread-hero">
  <div class="longread-hero-inner">
    <div class="eyebrow" style="justify-content:center;">AIIT-THRESI · Clinical reference</div>
    <h1>Save Lives Now.</h1>
    <p class="hero-sub">What you can do today with what already exists. 284 peer-reviewed citations. Every intervention available.</p>
    <div class="hero-meta">
      <div class="hm-cell"><div class="hm-k">Author</div><div class="hm-v">Rhet Dillard Wike</div></div>
      <div class="hm-cell"><div class="hm-k">Edition</div><div class="hm-v">First Publishable</div></div>
      <div class="hm-cell"><div class="hm-k">Length</div><div class="hm-v">500+ pages</div></div>
      <div class="hm-cell"><div class="hm-k">Citations</div><div class="hm-v">284 papers</div></div>
    </div>
    <div class="hero-warn">
      For informational purposes. Consult your healthcare provider. Every citation points to real, published, peer-reviewed research. Read them. Show them to your doctor. Make informed decisions together.
    </div>
    <a href="#toc" class="hero-cta">Read the book ↓</a>
  </div>
</section>

<div class="sln-search" id="sln-search">
  <div class="sln-search-inner">
    <svg class="sln-search-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
    <input id="sln-search-input" type="search" placeholder="Search the book — drug name, condition, intervention…" autocomplete="off" spellcheck="false" />
    <div class="sln-search-count" id="sln-search-count" aria-live="polite"></div>
    <button type="button" class="sln-search-btn" id="sln-search-prev" aria-label="Previous match" title="Previous (Shift+Enter)">↑</button>
    <button type="button" class="sln-search-btn" id="sln-search-next" aria-label="Next match" title="Next (Enter)">↓</button>
    <button type="button" class="sln-search-btn" id="sln-search-clear" aria-label="Clear search" title="Clear (Esc)">✕</button>
  </div>
  <div class="sln-search-sections" id="sln-search-sections" aria-live="polite"></div>
</div>

<article class="longread">
  <Content />
</article>

<a href="#top" id="backtotop" class="backtotop" aria-label="Back to top">↑ Top</a>

<script is:inline>
  (function () {
    // Assign IDs to h2 headings so anchor links work
    const article = document.querySelector('.longread');
    if (!article) return;
    const heads = article.querySelectorAll('h2, h3');
    heads.forEach(h => {
      if (!h.id) {
        h.id = h.textContent.toLowerCase()
          .replace(/[^\w\s-]/g, '')
          .trim()
          .replace(/\s+/g, '-')
          .slice(0, 60);
      }
    });
    // Back-to-top visibility
    const btn = document.getElementById('backtotop');
    if (btn) {
      window.addEventListener('scroll', () => {
        btn.classList.toggle('visible', window.scrollY > 800);
      });
    }

    // ====================================================================
    // SEARCH — client-side full-text search with highlights + jump-nav
    // ====================================================================
    const input    = document.getElementById('sln-search-input');
    const countEl  = document.getElementById('sln-search-count');
    const prevBtn  = document.getElementById('sln-search-prev');
    const nextBtn  = document.getElementById('sln-search-next');
    const clearBtn = document.getElementById('sln-search-clear');
    const sectEl   = document.getElementById('sln-search-sections');
    if (!input || !article) return;

    // Collect every text node in the article ONCE — we mutate during search,
    // but restore + re-collect each query.
    let originalHTML = article.innerHTML;
    let currentIdx = -1;
    let matches = [];

    function escapeHTML(s) { return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
    function escapeRegex(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

    function clearHighlights() {
      if (article.innerHTML !== originalHTML) article.innerHTML = originalHTML;
      matches = [];
      currentIdx = -1;
      countEl.textContent = '';
      sectEl.innerHTML = '';
      sectEl.classList.remove('visible');
      // Re-assign heading IDs after innerHTML reset
      article.querySelectorAll('h2, h3').forEach(h => {
        if (!h.id) {
          h.id = h.textContent.toLowerCase().replace(/[^\w\s-]/g,'').trim().replace(/\s+/g,'-').slice(0,60);
        }
      });
    }

    function highlight(query) {
      clearHighlights();
      const q = query.trim();
      if (q.length < 2) return;

      const rx = new RegExp(escapeRegex(q), 'gi');

      // Walk text nodes only — do NOT touch tag attributes
      const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT, {
        acceptNode: (n) => (n.parentNode && n.parentNode.nodeName.match(/^(SCRIPT|STYLE)$/i))
          ? NodeFilter.FILTER_REJECT : NodeFilter.FILTER_ACCEPT
      });
      const textNodes = [];
      let node;
      while ((node = walker.nextNode())) textNodes.push(node);

      textNodes.forEach(tn => {
        const text = tn.nodeValue;
        if (!rx.test(text)) { rx.lastIndex = 0; return; }
        rx.lastIndex = 0;
        const frag = document.createDocumentFragment();
        let lastIdx = 0;
        let m;
        while ((m = rx.exec(text)) !== null) {
          if (m.index > lastIdx) frag.appendChild(document.createTextNode(text.slice(lastIdx, m.index)));
          const mark = document.createElement('mark');
          mark.className = 'sln-hl';
          mark.textContent = m[0];
          frag.appendChild(mark);
          lastIdx = m.index + m[0].length;
          if (m[0].length === 0) rx.lastIndex++; // zero-width guard
        }
        if (lastIdx < text.length) frag.appendChild(document.createTextNode(text.slice(lastIdx)));
        tn.parentNode.replaceChild(frag, tn);
      });

      matches = Array.from(article.querySelectorAll('mark.sln-hl'));

      // Build per-section match summary (top 12 sections)
      const sectionCounts = new Map();
      matches.forEach(m => {
        let el = m;
        while (el && el !== article) {
          if (el.previousElementSibling || el.parentElement === article) break;
          el = el.parentElement;
        }
        // Walk backward to find the nearest h2/h3 heading
        let heading = null;
        let cursor = m;
        while (cursor && cursor !== article) {
          let sib = cursor.previousElementSibling;
          while (sib) {
            if (sib.tagName === 'H2' || sib.tagName === 'H3') { heading = sib; break; }
            sib = sib.previousElementSibling;
          }
          if (heading) break;
          cursor = cursor.parentElement;
        }
        if (heading) {
          const key = heading.id + '::' + heading.textContent.trim();
          sectionCounts.set(key, (sectionCounts.get(key) || 0) + 1);
        }
      });

      if (sectionCounts.size > 0) {
        const entries = Array.from(sectionCounts.entries())
          .sort((a, b) => b[1] - a[1])
          .slice(0, 12);
        const html = entries.map(([key, n]) => {
          const [id, title] = key.split('::');
          return '<a href="#' + id + '" class="sln-sec-chip" data-id="' + id + '"><span class="sln-sec-t">' + escapeHTML(title) + '</span><span class="sln-sec-n">' + n + '</span></a>';
        }).join('');
        sectEl.innerHTML = html;
        sectEl.classList.add('visible');
      }

      if (matches.length > 0) {
        currentIdx = 0;
        gotoMatch(0);
      }
      updateCount();
    }

    function updateCount() {
      if (matches.length === 0) {
        countEl.textContent = input.value.trim().length >= 2 ? 'no matches' : '';
        return;
      }
      countEl.textContent = (currentIdx + 1) + ' / ' + matches.length;
    }

    function gotoMatch(i) {
      matches.forEach(m => m.classList.remove('sln-hl-active'));
      if (i < 0 || i >= matches.length) return;
      const m = matches[i];
      m.classList.add('sln-hl-active');
      m.scrollIntoView({ behavior: 'smooth', block: 'center' });
      updateCount();
    }

    function next() { if (!matches.length) return; currentIdx = (currentIdx + 1) % matches.length; gotoMatch(currentIdx); }
    function prev() { if (!matches.length) return; currentIdx = (currentIdx - 1 + matches.length) % matches.length; gotoMatch(currentIdx); }

    let debounce;
    input.addEventListener('input', () => {
      clearTimeout(debounce);
      debounce = setTimeout(() => highlight(input.value), 160);
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); (e.shiftKey ? prev : next)(); }
      else if (e.key === 'Escape') { input.value = ''; clearHighlights(); input.blur(); }
    });
    nextBtn.addEventListener('click', next);
    prevBtn.addEventListener('click', prev);
    clearBtn.addEventListener('click', () => { input.value = ''; clearHighlights(); input.focus(); });

    // Delegated section-chip click: just let href do its job, but also jump to first match inside
    sectEl.addEventListener('click', (e) => {
      const chip = e.target.closest('.sln-sec-chip');
      if (!chip) return;
      // Find first match under this heading and make it the active one
      const id = chip.getAttribute('data-id');
      const h = document.getElementById(id);
      if (!h) return;
      // After clicking the chip, currentIdx advances to the first match in that section
      const idx = matches.findIndex(m => {
        let cur = m;
        while (cur && cur !== article) {
          let sib = cur.previousElementSibling;
          while (sib) {
            if (sib === h) return true;
            if (sib.tagName === 'H2' || sib.tagName === 'H3') return false;
            sib = sib.previousElementSibling;
          }
          cur = cur.parentElement;
        }
        return false;
      });
      if (idx >= 0) { currentIdx = idx; gotoMatch(idx); }
    });

    // Keyboard shortcut: "/" focuses search (unless already in an input)
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && !['INPUT','TEXTAREA'].includes(document.activeElement.tagName)) {
        e.preventDefault(); input.focus(); input.select();
      }
    });
  })();
</script>

<style>
  :global(body) { scroll-behavior: smooth; }

  .longread-hero {
    padding: 140px 24px 60px;
    text-align: center;
    border-bottom: 1px solid var(--edge);
    background: radial-gradient(ellipse at center top, rgba(212,160,96,0.06) 0%, transparent 60%);
  }
  .longread-hero-inner { max-width: 820px; margin: 0 auto; }
  .longread-hero h1 {
    font-size: clamp(56px, 10vw, 120px);
    line-height: 1;
    margin: 16px 0 24px;
    letter-spacing: -0.02em;
  }
  .hero-sub {
    color: var(--muted-hi);
    font-size: clamp(17px, 2.2vw, 22px);
    line-height: 1.5;
    max-width: 640px;
    margin: 0 auto 40px;
  }
  .hero-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0;
    border-top: 1px solid var(--edge);
    border-bottom: 1px solid var(--edge);
    margin: 36px 0;
  }
  .hm-cell {
    padding: 22px 16px;
    border-right: 1px solid var(--edge);
  }
  .hm-cell:last-child { border-right: none; }
  .hm-k {
    font-family: 'Courier New', monospace;
    font-size: 9pt; letter-spacing: 0.28em;
    color: var(--muted); text-transform: uppercase;
    margin-bottom: 6px;
  }
  .hm-v {
    font-family: 'Georgia', serif;
    font-size: 16px;
    color: var(--ink);
  }
  .hero-warn {
    max-width: 620px; margin: 0 auto 40px;
    padding: 20px 24px;
    border: 1px solid var(--edge);
    border-radius: 4px;
    background: rgba(10,10,18,0.4);
    color: var(--ink-soft);
    font-size: 14px; line-height: 1.65;
    text-align: left;
  }
  .hero-cta {
    display: inline-block;
    font-family: 'Courier New', monospace;
    font-size: 11pt; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--amber);
    padding: 16px 36px;
    border: 1px solid var(--amber);
    border-radius: 3px;
    text-decoration: none;
    transition: background 0.25s, color 0.25s;
  }
  .hero-cta:hover { background: var(--amber); color: #0a0a12; }

  .longread {
    max-width: 760px;
    margin: 0 auto;
    padding: 80px 24px 160px;
    font-family: 'Georgia', serif;
    color: var(--ink);
    line-height: 1.72;
    font-size: 18px;
  }

  .longread :global(h1) {
    font-family: 'Georgia', serif;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.1;
    margin: 96px 0 28px;
    padding-top: 40px;
    border-top: 1px solid var(--edge);
    color: #ffffff;
    letter-spacing: -0.015em;
  }
  .longread :global(h1:first-child) {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }
  .longread :global(h2) {
    font-family: 'Georgia', serif;
    font-size: clamp(26px, 3.4vw, 36px);
    line-height: 1.2;
    margin: 64px 0 20px;
    color: var(--amber);
    letter-spacing: -0.01em;
    scroll-margin-top: 80px;
  }
  .longread :global(h3) {
    font-family: 'Courier New', monospace;
    font-size: 12pt;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 44px 0 18px;
    color: var(--teal);
    scroll-margin-top: 80px;
  }
  .longread :global(h4) {
    font-family: 'Georgia', serif;
    font-size: 20px;
    margin: 32px 0 14px;
    color: var(--ink);
  }
  .longread :global(p) {
    margin: 0 0 22px;
    color: var(--ink);
  }
  .longread :global(strong) {
    color: #ffffff;
    font-weight: 600;
  }
  .longread :global(em) { color: var(--ink); }
  .longread :global(a) {
    color: var(--amber);
    text-decoration: none;
    border-bottom: 1px solid rgba(212,160,96,0.35);
    transition: border-color 0.2s, color 0.2s;
  }
  .longread :global(a:hover) {
    color: #ffd98a;
    border-bottom-color: var(--amber);
  }
  .longread :global(ul),
  .longread :global(ol) {
    margin: 0 0 26px;
    padding-left: 28px;
  }
  .longread :global(li) {
    margin-bottom: 10px;
    color: var(--ink);
  }
  .longread :global(li::marker) { color: var(--muted); }
  .longread :global(hr) {
    border: none;
    border-top: 1px solid var(--edge);
    margin: 56px 0;
  }
  .longread :global(blockquote) {
    margin: 28px 0;
    padding: 4px 0 4px 24px;
    border-left: 2px solid var(--amber);
    color: var(--ink-soft);
    font-style: italic;
  }
  .longread :global(code) {
    font-family: 'Courier New', monospace;
    font-size: 0.92em;
    background: rgba(10,10,18,0.7);
    padding: 2px 8px;
    border-radius: 3px;
    color: var(--teal);
  }
  .longread :global(pre) {
    font-family: 'Courier New', monospace;
    font-size: 13px;
    line-height: 1.55;
    background: rgba(10,10,18,0.7);
    padding: 20px 22px;
    border-radius: 4px;
    border: 1px solid var(--edge);
    overflow-x: auto;
    margin: 22px 0;
  }
  .longread :global(pre code) {
    background: transparent;
    padding: 0;
    color: var(--ink);
  }
  .longread :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 28px 0;
    font-size: 15px;
  }
  .longread :global(th),
  .longread :global(td) {
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid var(--edge);
  }
  .longread :global(th) {
    font-family: 'Courier New', monospace;
    font-size: 9pt;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
  }

  /* =========================
     Search bar
     ========================= */
  .sln-search {
    position: sticky;
    top: 72px;
    z-index: 40;
    background: rgba(10,10,18,0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid var(--edge);
    border-bottom: 1px solid var(--edge);
    padding: 14px 24px 0;
  }
  .sln-search-inner {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .sln-search-icon {
    color: var(--muted);
    flex: 0 0 auto;
  }
  #sln-search-input {
    flex: 1 1 auto;
    background: transparent;
    border: none;
    outline: none;
    color: var(--ink);
    font-size: 16px;
    padding: 10px 4px;
    font-family: 'Georgia', serif;
  }
  #sln-search-input::placeholder { color: var(--muted); font-style: italic; }
  .sln-search-count {
    font-family: 'Courier New', monospace;
    font-size: 10pt;
    letter-spacing: 0.14em;
    color: var(--amber);
    min-width: 60px;
    text-align: right;
  }
  .sln-search-btn {
    background: transparent;
    border: 1px solid var(--edge);
    color: var(--muted-hi);
    border-radius: 3px;
    padding: 6px 10px;
    font-family: 'Courier New', monospace;
    font-size: 12px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .sln-search-btn:hover { color: var(--amber); border-color: var(--amber); }
  .sln-search-sections {
    max-width: 820px;
    margin: 0 auto;
    display: none;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px 0 12px;
  }
  .sln-search-sections.visible { display: flex; }
  .sln-sec-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(212,160,96,0.08);
    border: 1px solid rgba(212,160,96,0.35);
    border-radius: 999px;
    padding: 4px 10px 4px 12px;
    text-decoration: none;
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: var(--ink-soft);
    transition: background 0.2s, border-color 0.2s;
  }
  .sln-sec-chip:hover {
    background: rgba(212,160,96,0.16);
    border-color: var(--amber);
  }
  .sln-sec-chip .sln-sec-t { color: var(--ink-soft); }
  .sln-sec-chip .sln-sec-n {
    background: var(--amber);
    color: #0a0a12;
    font-weight: 700;
    min-width: 20px;
    text-align: center;
    border-radius: 999px;
    padding: 1px 7px;
    font-size: 10px;
  }
  /* Highlight marks within the article */
  .longread :global(mark.sln-hl) {
    background: rgba(212,160,96,0.25);
    color: var(--ink);
    padding: 0 2px;
    border-radius: 2px;
  }
  .longread :global(mark.sln-hl-active) {
    background: var(--amber);
    color: #0a0a12;
    box-shadow: 0 0 0 2px rgba(212,160,96,0.35);
  }
  @media (max-width: 680px) {
    .sln-search { top: 60px; padding: 10px 14px 0; }
    #sln-search-input { font-size: 15px; }
    .sln-search-count { min-width: 44px; font-size: 9pt; }
    .sln-search-btn { padding: 5px 8px; }
  }

  .backtotop {
    position: fixed;
    bottom: 28px; right: 28px;
    font-family: 'Courier New', monospace;
    font-size: 10pt; letter-spacing: 0.22em; text-transform: uppercase;
    padding: 12px 18px;
    background: rgba(10,10,18,0.85);
    border: 1px solid var(--edge);
    border-radius: 3px;
    color: var(--amber);
    text-decoration: none;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s, border-color 0.3s;
    z-index: 90;
    backdrop-filter: blur(6px);
  }
  .backtotop.visible { opacity: 1; pointer-events: auto; }
  .backtotop:hover { border-color: var(--amber); }

  @media (max-width: 760px) {
    .longread { padding: 56px 22px 120px; font-size: 16px; line-height: 1.68; }
    .longread :global(h1) { margin: 72px 0 22px; padding-top: 32px; }
    .longread :global(h2) { margin: 48px 0 16px; }
    .longread :global(h3) { margin: 36px 0 14px; }
    .hero-meta { grid-template-columns: repeat(2, 1fr); }
    .hm-cell:nth-child(2n) { border-right: none; }
    .hm-cell:nth-child(-n+2) { border-bottom: 1px solid var(--edge); }
    .backtotop { bottom: 16px; right: 16px; padding: 10px 14px; font-size: 9pt; }
  }
</style>

<Interlink links={["drugs", "validation"]} />
<ReturnToBuddy />

</Layout>
