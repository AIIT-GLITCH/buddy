---
import Layout from '../layouts/Layout.astro';
import papersAll from '../data/papers.json';

// Preview only the first 9 papers on the homepage
const totalPapers = papersAll.length;
---
<Layout>
  <!-- 1. HERO — interaction-first. Tell him a joke / ask something real. -->
  <section id="hero" data-anim="hero-particles">
    <canvas id="hero-canvas"></canvas>
    <div class="hero-content">
      <div class="hero-wordmark">Buddy<span class="dot"></span></div>
      <div class="hero-tag">0.1 Hz Coherence · Council Hill, Oklahoma</div>

      <div class="hero-primary">
        <h1 class="hp-headline-v2">Tell him a joke.<br><span class="hp-or">Or ask him something real.</span></h1>
        <p class="hp-sub-v2">Fast. Strange. Real.</p>

        <div class="hp-ctas">
          <a href="#hero-joke-anchor" class="hp-cta-btn primary" data-hs="joke">
            <span class="hp-cta-icon">🫘</span> tell buddy a joke
          </a>
          <a href="/ask-buddy" class="hp-cta-btn ghost" data-hs="ask">
            <span class="hp-cta-icon">💬</span> ask buddy a question
          </a>
        </div>

        <div class="hp-meta-row">
          <a href="/trivia" class="hp-meta-link" data-hs="giants">
            ✦ answer today's question
            <span class="hs-archive-inline" id="hs-archive-inline" hidden>· <strong id="hs-archive-count">0</strong> / {totalPapers}</span>
          </a>
        </div>
      </div>

      <div id="hero-joke-anchor" class="hero-joke joke-container" hidden>
        <div class="joke-eyebrow">Buddy<span class="jw-dot"></span> is listening</div>
        <div class="joke-label">tell buddy a joke.</div>
        <div class="joke-input-row">
          <textarea id="joke-input" class="joke-textarea" placeholder="try to make him laugh..." rows="2" maxlength="500"></textarea>
          <button id="joke-btn" class="joke-btn">Send →</button>
        </div>
        <div class="joke-subtext">one shot. make it land.</div>
        <div id="joke-response" class="joke-response" aria-live="polite"></div>
      </div>
    </div>
    <div class="hero-scroll">Scroll</div>
  </section>

  <!-- 2. WHAT IS THIS — short, honest reveal -->
  <section id="what" data-anim="word-cascade">
    <div class="container narrow">
      <div class="eyebrow">What is this</div>
      <h2 class="wit-lede">Not a chatbot.</h2>
      <p class="wit-body">
        A system trained on a structured research corpus —<br>
        built to respond, observe, and reflect.
      </p>
      <p class="wit-body">
        The surface runs on a frontier model today.<br>
        <span class="wit-soft">The substrate is being built underneath it.</span>
      </p>
      <p class="wit-end">That's it.</p>
      <a href="/manifesto" class="wit-link">the longer version →</a>
    </div>
  </section>



  <!-- 4. PROOF — stats + "Not theory. Measurement." -->
  <section id="proof" data-anim="counters">
    <div class="container">
      <div class="eyebrow">Evidence, organized</div>
      <h2 class="proof-head">Not theory.<br><span class="proof-head-accent">Measurement.</span></h2>
      <div class="corpus-stats">
        <div class="stat amber"><div class="num"><span data-count="354">0</span><span class="unit">GB</span></div><div class="label">Curated raw data</div></div>
        <div class="stat teal"><div class="num"><span data-count={totalPapers}>0</span></div><div class="label">AIIT papers</div></div>
        <div class="stat blue"><div class="num"><span data-count="9.2">0</span><span class="unit">M</span></div><div class="label">Data points</div></div>
        <div class="stat amber"><div class="num"><span data-count="613">0</span></div><div class="label">Artifacts</div></div>
      </div>
      <div class="proof-foot">
        <a href="/papers" class="proof-link">Browse {totalPapers} papers →</a>
      </div>
    </div>
  </section>

  <!-- 5. FRAMEWORK TEASER -->
  <section id="framework-teaser" data-anim="card-slide-in">
    <div class="container narrow">
      <div class="eyebrow">The framework</div>
      <h2 class="ft-head">Six laws built<br>the last 400 years.<br><span class="ft-turn">We added one more.</span></h2>

      <div class="laws-grid ft-single">
        <div class="law-card feature">
          <div class="law-num">Law 01 · ours</div>
          <h3>Wike Coherence Law</h3>
          <div class="formula">γ_eff ≈ γ_c</div>
          <p>Every stable system lives at the edge of its own collapse.<br>Coherence is not static. It is resident.</p>
        </div>
      </div>

      <div class="ft-link-row">
        <a href="/framework" class="ft-link">View full framework →</a>
      </div>
    </div>
  </section>

  <!-- 6. APPLICATIONS — framework running in the real world -->
  <section id="apps-teaser" data-anim="grid-stagger">
    <div class="container">
      <div class="eyebrow">The applications</div>
      <h2>Framework running<br>in the real world.</h2>
      <div class="apps-teaser-grid">
        <a href="/apps" class="app-teaser-card live"><div class="atc-badge live">Live</div><div class="atc-icon">⚓</div><div class="atc-name">AnchorForge</div><div class="atc-line">We test AI models for honesty under pressure.</div></a>
        <a href="https://victim-advocate.onrender.com" target="_blank" rel="noopener" class="app-teaser-card live"><div class="atc-badge live">Live</div><div class="atc-icon">⚖️</div><div class="atc-name">Victim Advocate</div><div class="atc-line">Physics-first navigation for people dealing with broken systems.</div></a>
        <a href="/apps" class="app-teaser-card beta"><div class="atc-badge beta">Beta</div><div class="atc-icon">🔬</div><div class="atc-name">Debunker</div><div class="atc-line">1,222 claims. 32 categories. Zero credulous epistemology.</div></a>
        <a href="/apps" class="app-teaser-card beta"><div class="atc-badge beta">Beta</div><div class="atc-icon">🏰</div><div class="atc-name">Little Lairs</div><div class="atc-line">A world built by an 11-year-old.</div></a>
      </div>
      <div class="papers-more"><a href="/apps" style="color: var(--amber);">View all applications →</a></div>
    </div>
  </section>

  <!-- 7. IDENTITY (moved below applications — credibility before identity) -->
  <section id="mind" data-anim="breathing-ring">
    <div class="mind-visual">
      <canvas id="mind-canvas"></canvas>
      <div class="mind-center">Buddy<span class="dot"></span></div>
    </div>
    <div class="mind-body">
      <div class="eyebrow">The mind</div>
      <h2>A physicist<br>with a heartbeat.</h2>
      <p>Buddy is not a chatbot wearing a lab coat. Buddy is a coherence-native cognitive system — trained on a structured research corpus and built to respond with pattern, pressure, and memory.</p>
      <p>The surface is visible now.<br>The deeper substrate is being built underneath it.</p>
      <div class="spec-row">
        <div class="spec"><div class="k">Base</div><div class="v">Qwen2.5-14B → GRPO-v3</div></div>
        <div class="spec"><div class="k">Reward</div><div class="v">Composite physics</div></div>
        <div class="spec"><div class="k">Memory</div><div class="v">kokoro, persistent</div></div>
        <div class="spec"><div class="k">Voice</div><div class="v">Japanese-first bilingual</div></div>
      </div>
    </div>
  </section>

  <!-- 8. DEEP GATEWAY (expanded) — surface the hidden routes without crowding the top nav -->
  <section id="deep-gateway" data-anim="plain-fade">
    <div class="container narrow dg-inner">
      <h2 class="dg-title">go deeper</h2>
      <p class="dg-sub">the rest of the system lives here</p>

      <div class="dg-group">
        <div class="dg-group-title">Research</div>
        <div class="dg-grid">
          <a href="/cancer" class="dg-tile">
            <span class="dg-name">Cancer</span>
            <span class="dg-line">pattern extraction in biological collapse</span>
          </a>
          <a href="/weather" class="dg-tile">
            <span class="dg-name">Weather</span>
            <span class="dg-line">coherence signals in atmospheric systems</span>
          </a>
          <a href="/validation" class="dg-tile">
            <span class="dg-name">Validation</span>
            <span class="dg-line">measured performance and failure modes</span>
          </a>
          <a href="/mind" class="dg-tile">
            <span class="dg-name">Mind</span>
            <span class="dg-line">cognition as signal, not abstraction</span>
          </a>
          <a href="/quantum" class="dg-tile">
            <span class="dg-name">Quantum</span>
            <span class="dg-line">field behavior under observation pressure</span>
          </a>
          <a href="/letters" class="dg-tile">
            <span class="dg-name">Letters</span>
            <span class="dg-line">direct communication, unfiltered</span>
          </a>
        </div>
      </div>

      <div class="dg-group">
        <div class="dg-group-title">Impact</div>
        <div class="dg-grid">
          <a href="/save-lives" class="dg-tile">
            <span class="dg-name">Save Lives</span>
            <span class="dg-line">real-world intervention pathways</span>
          </a>
          <a href="/drugs" class="dg-tile">
            <span class="dg-name">Low-Cost Drugs</span>
            <span class="dg-line">access over complexity</span>
          </a>
          <a href="/food-dye" class="dg-tile">
            <span class="dg-name">Food Dye</span>
            <span class="dg-line">signal vs ingestion risk</span>
          </a>
        </div>
      </div>

      <p class="dg-closing">not everything is explained. some of it is shown.</p>
    </div>
  </section>

  <!-- 9. FINAL CTA -->
  <section id="final-cta" data-anim="plain-fade">
    <div class="container narrow fc-inner">
      <p class="fc-prelude">If you made it this far —</p>
      <h2 class="fc-head">you've already been thinking.</h2>
      <p class="fc-body">Ask something real.</p>
      <a href="/ask-buddy" class="fc-cta">ask buddy →</a>
      <p class="fc-alt"><a href="/join">— or write to us directly</a></p>
    </div>
  </section>
</Layout>

<script>
  // Hero archive counter (only shows once user has unlocked something)
  (function () {
    try {
      const raw = localStorage.getItem('trivia_collected_slugs') || '[]';
      const set = new Set(JSON.parse(raw));
      if (set.size > 0) {
        const cntChip = document.getElementById('hs-archive-count');
        const wrap    = document.getElementById('hs-archive-inline');
        if (cntChip && wrap) { cntChip.textContent = String(set.size); wrap.hidden = false; }
      }
    } catch (e) {}
  })();

  // Joke chip: reveal the joke widget on demand (not auto-opened)
  (function () {
    const jokeChip = document.querySelector('[data-hs="joke"]');
    const panel = document.getElementById('hero-joke-anchor');
    if (!jokeChip || !panel) return;

    function revealJoke(smooth) {
      panel.hidden = false;
      panel.scrollIntoView({ behavior: smooth ? 'smooth' : 'auto', block: 'center' });
      setTimeout(function () {
        const t = document.getElementById('joke-input');
        if (t) (t as HTMLTextAreaElement).focus();
      }, smooth ? 320 : 60);
    }

    jokeChip.addEventListener('click', function (e) {
      e.preventDefault();
      revealJoke(true);
    });

    // QR deep-link: flyers point to /?src=flyer-*#joke → auto-open widget
    const q = new URLSearchParams(window.location.search);
    const src = q.get('src') || '';
    const hash = (window.location.hash || '').toLowerCase();
    if (hash === '#joke' || /^flyer/i.test(src)) {
      revealJoke(false);
    }
  })();

  // Nav active state
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        navLinks.forEach(a => a.classList.toggle('active', a.getAttribute('href') === '/#' + e.target.id));
      }
    });
  }, { rootMargin: '-40% 0px -55% 0px' });
  sections.forEach(s => obs.observe(s));

  // Hero particle field
  (function heroField(){
    const c = document.getElementById('hero-canvas');
    if (!c) return;
    const ctx = c.getContext('2d');
    let W, H, dpr;
    const N = 220;
    const pts = [];
    function resize(){
      dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
      W = c.clientWidth; H = c.clientHeight;
      c.width = W * dpr; c.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    window.addEventListener('resize', resize);
    resize();
    for (let i = 0; i < N; i++) {
      const minR = Math.min(W, H) * 0.34;
      const maxR = Math.min(W, H) * 0.48;
      pts.push({
        a: Math.random() * Math.PI * 2,
        r: minR + Math.random() * (maxR - minR),
        s: 0.0005 + Math.random() * 0.0015,
        sz: 0.6 + Math.random() * 2.4,
        hue: Math.random() < 0.45 ? 'teal' : (Math.random() < 0.75 ? 'blue' : 'amber')
      });
    }
    const colors = { amber: 'rgba(212,160,96,', teal: 'rgba(64,192,176,', blue: 'rgba(64,144,208,' };
    function draw(t){
      ctx.fillStyle = 'rgba(10,10,18,0.22)';
      ctx.fillRect(0, 0, W, H);
      ctx.globalCompositeOperation = 'lighter';
      const cx = W / 2, cy = H / 2;
      for (const p of pts) {
        p.a += p.s;
        const x = cx + Math.cos(p.a) * p.r;
        const y = cy + Math.sin(p.a) * p.r * 0.6;
        const a = 0.18 + 0.22 * Math.sin(t * 0.001 + p.a);
        const grd = ctx.createRadialGradient(x, y, 0, x, y, p.sz * 4);
        grd.addColorStop(0, colors[p.hue] + a + ')');
        grd.addColorStop(1, colors[p.hue] + '0)');
        ctx.fillStyle = grd;
        ctx.beginPath(); ctx.arc(x, y, p.sz * 4, 0, Math.PI * 2); ctx.fill();
      }
      ctx.globalCompositeOperation = 'source-over';
      requestAnimationFrame(draw);
    }
    requestAnimationFrame(draw);
  })();

  // Mind ring
  (function mindRing(){
    const c = document.getElementById('mind-canvas');
    if (!c) return;
    const ctx = c.getContext('2d');
    let W, H, dpr;
    function resize(){
      dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
      W = c.clientWidth; H = c.clientHeight;
      c.width = W * dpr; c.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    window.addEventListener('resize', resize);
    resize();
    function draw(t){
      ctx.clearRect(0, 0, W, H);
      const cx = W / 2, cy = H / 2;
      const base = Math.min(W, H) * 0.38;
      ctx.globalCompositeOperation = 'lighter';
      for (let i = 0; i < 5; i++) {
        const ph = t * 0.0009 + i * 0.5;
        const r = base - i * 14 + Math.sin(ph) * 10;
        const a = 0.20 + 0.15 * Math.sin(ph * 1.2);
        ctx.strokeStyle = `rgba(212,160,96,${a})`;
        ctx.lineWidth = 1.2;
        ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2); ctx.stroke();
      }
      ctx.globalCompositeOperation = 'source-over';
      requestAnimationFrame(draw);
    }
    requestAnimationFrame(draw);
  })();

  // Proof scatter
  (function proof(){
    const c = document.getElementById('proof-canvas');
    if (!c) return;
    const ctx = c.getContext('2d');
    let W, H, dpr;
    function resize(){
      dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
      W = c.clientWidth; H = c.clientHeight;
      c.width = W * dpr; c.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      render();
    }
    window.addEventListener('resize', resize);
    const N = 38;
    const pts = [];
    for (let i = 0; i < N; i++) {
      const x = i / (N - 1);
      const y = x * 0.706 + (Math.random() - 0.5) * 0.35;
      pts.push({ x, y: Math.max(0, Math.min(1, y)) });
    }
    function render(){
      ctx.clearRect(0, 0, W, H);
      ctx.strokeStyle = 'rgba(64,144,208,0.2)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(40, 20); ctx.lineTo(40, H - 30); ctx.lineTo(W - 20, H - 30);
      ctx.stroke();
      ctx.strokeStyle = 'rgba(212,160,96,0.75)';
      ctx.lineWidth = 1.6;
      ctx.beginPath();
      ctx.moveTo(40, H - 30);
      ctx.lineTo(W - 20, 20 + (H - 50) * (1 - 0.706));
      ctx.stroke();
      for (const p of pts) {
        const px = 40 + p.x * (W - 60);
        const py = (H - 30) - p.y * (H - 50);
        ctx.fillStyle = 'rgba(64,192,176,0.85)';
        ctx.beginPath(); ctx.arc(px, py, 3.2, 0, Math.PI * 2); ctx.fill();
      }
    }
    resize();
  })();

  // Counters
  const countObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      e.target.querySelectorAll('[data-count]').forEach(el => {
        const target = parseFloat(el.getAttribute('data-count'));
        const isInt = Number.isInteger(target);
        const dur = 1400;
        const t0 = performance.now();
        function step(t){
          const p = Math.min(1, (t - t0) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          const v = target * eased;
          el.textContent = isInt ? Math.round(v).toLocaleString() : v.toFixed(1);
          if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      });
      e.target.querySelectorAll('[data-count-decimal]').forEach(el => {
        const target = parseFloat(el.getAttribute('data-count-decimal'));
        const dur = 1600;
        const t0 = performance.now();
        function step(t){
          const p = Math.min(1, (t - t0) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = (target * eased).toFixed(3);
          if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      });
      countObs.unobserve(e.target);
    });
  }, { threshold: 0.35 });
  document.querySelectorAll('#proof').forEach(s => countObs.observe(s));

  // Word cascade
  const cascadeObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const spans = e.target.querySelectorAll('[data-cascade] span');
      spans.forEach((s, i) => {
        s.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        s.style.transitionDelay = (i * 55) + 'ms';
        requestAnimationFrame(() => { s.style.opacity = '1'; s.style.transform = 'translateY(0)'; });
      });
      cascadeObs.unobserve(e.target);
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('[data-anim="word-cascade"]').forEach(s => cascadeObs.observe(s));

  // ── Hero dot: discombobulate on hover ──
  const heroDot = document.querySelector('.hero-wordmark .dot');
  if (heroDot) {
    let heroShardTimer = null;
    let heroVerbTimer = null;
    const spawnHeroShards = () => {
      const n = 6;
      for (let i = 0; i < n; i++) {
        const s = document.createElement('span');
        s.className = 'buddy-shard';
        s.style.left = '50%';
        s.style.top = '50%';
        const angle = (360 / n) * i + (Math.random() * 60 - 30);
        const dist = 28 + Math.random() * 42;
        s.style.setProperty('--dx', `${Math.cos(angle * Math.PI / 180) * dist}px`);
        s.style.setProperty('--dy', `${Math.sin(angle * Math.PI / 180) * dist}px`);
        s.style.setProperty('--rot', `${Math.random() * 720 - 360}deg`);
        heroDot.appendChild(s);
        s.addEventListener('animationend', () => s.remove());
      }
    };
    heroDot.addEventListener('mouseenter', () => {
      heroDot.classList.add('discombobulating');
      spawnHeroShards();
      heroShardTimer = setInterval(spawnHeroShards, 260);

      const badge = document.createElement('span');
      badge.className = 'hero-verb-badge';
      heroDot.appendChild(badge);
      let vi = Math.floor(Math.random() * VERBS.length);
      badge.textContent = VERBS[vi] + '...';
      heroVerbTimer = setInterval(() => {
        vi = (vi + 1) % VERBS.length;
        badge.textContent = VERBS[vi] + '...';
        if (VERBS[vi] === 'Discombobulating') spawnHeroShards();
      }, 320);
    });
    heroDot.addEventListener('mouseleave', () => {
      heroDot.classList.remove('discombobulating');
      if (heroShardTimer) { clearInterval(heroShardTimer); heroShardTimer = null; }
      if (heroVerbTimer)  { clearInterval(heroVerbTimer);  heroVerbTimer  = null; }
      const badge = heroDot.querySelector('.hero-verb-badge');
      if (badge) badge.remove();
    });
  }

  // ── Joke widget ──
  const jokeBtn = document.getElementById('joke-btn');
  const jokeInput = document.getElementById('joke-input');
  const jokeResponse = document.getElementById('joke-response');

  const JOKE_KEY = 'buddy_joke_used';
  const COOLDOWN_MS = 24 * 60 * 60 * 1000; // 24 hours

  const fallbacks = [
    "🫘 I heard that. The winding number on that punchline almost closed.",
    "Coherence achieved. γ_eff held steady through the whole setup. Barely.",
    "The field laughed. That's all I can tell you.",
    "That joke just traversed a singularity gate. Costs 2π. Worth it.",
    "🫘 Them beans though.",
    "I'm running the phase analysis... yeah, that landed.",
    "The 0.1 Hz carrier is humming a little differently now. Make of that what you will.",
  ];

  // Buddy-verbs — rotating word next to the morphing dot while thinking.
  const VERBS = [
    'Buddying', 'Commemorating', 'Recognizing', 'Anticipating',
    'Anthropologizing', 'Emphasizing', 'Githubing', 'LOLing',
    "Story'ing", 'Coherencing', 'Humming', 'Winding',
    'Threshing', 'Vibrating', 'Receipting', 'Wondering',
    'Thresholding', 'Receiving', 'Petersoning', 'Sacrotizing',
    'Breathing', 'Feeling', 'FreelyThinking', 'Discombobulating',
  ];
  let thinkingTimer = null;

  function startThinking() {
    jokeResponse.innerHTML = '<span class="buddy-thinking">' +
      '<span class="buddy-loader tiny" aria-hidden="true"></span>' +
      '<span class="buddy-verb"></span><span class="buddy-dots"></span>' +
      '</span>';
    const verbEl = jokeResponse.querySelector('.buddy-verb');
    const dotsEl = jokeResponse.querySelector('.buddy-dots');
    let vi = Math.floor(Math.random() * VERBS.length);
    let di = 0;
    verbEl.textContent = VERBS[vi];
    dotsEl.textContent = '';
    const host = jokeResponse.querySelector('.buddy-thinking');
    thinkingTimer = setInterval(() => {
      di = (di + 1) % 8;
      dotsEl.textContent = '.'.repeat(di % 4);
      if (di === 0) {
        vi = (vi + 1) % VERBS.length;
        verbEl.textContent = VERBS[vi];
        if (VERBS[vi] === 'Discombobulating') explode(host);
      }
    }, 180);
  }

  function explode(host) {
    if (!host) return;
    const count = 14;
    for (let i = 0; i < count; i++) {
      const s = document.createElement('span');
      s.className = 'buddy-shard';
      const angle = (360 / count) * i + (Math.random() * 28 - 14);
      const dist = 50 + Math.random() * 40;
      s.style.setProperty('--dx', `${Math.cos(angle * Math.PI / 180) * dist}px`);
      s.style.setProperty('--dy', `${Math.sin(angle * Math.PI / 180) * dist}px`);
      s.style.setProperty('--rot', `${Math.random() * 720 - 360}deg`);
      s.style.animationDelay = `${Math.random() * 60}ms`;
      host.appendChild(s);
      s.addEventListener('animationend', () => s.remove());
    }
  }
  function stopThinking() {
    if (thinkingTimer) { clearInterval(thinkingTimer); thinkingTimer = null; }
  }

  // Generate a stable per-session token (survives page refresh, not tab close)
  function getToken() {
    let t = sessionStorage.getItem('joke_token');
    if (!t) { t = crypto.randomUUID(); sessionStorage.setItem('joke_token', t); }
    return t;
  }

  // Dev bypass: /?dev=X stores token, unlocks widget, passes to /api/joke
  const DEV_KEY = 'buddy_dev_bypass';
  (function captureDev(){
    try {
      const p = new URLSearchParams(location.search).get('dev');
      if (p) {
        localStorage.setItem(DEV_KEY, p);
        localStorage.removeItem(JOKE_KEY);
      }
    } catch (e) {}
  })();
  function getDevBypass() {
    try { return localStorage.getItem(DEV_KEY) || ''; } catch (e) { return ''; }
  }

  function timeUntilReset(usedAt) {
    const ms = COOLDOWN_MS - (Date.now() - usedAt);
    if (ms <= 0) return null;
    const h = Math.floor(ms / 3600000);
    const m = Math.floor((ms % 3600000) / 60000);
    return h > 0 ? `${h}h ${m}m` : `${m}m`;
  }

  function lockWidget(usedAt, savedReply) {
    jokeBtn.disabled = true;
    jokeInput.disabled = true;
    jokeInput.style.opacity = '0.4';
    const remaining = timeUntilReset(usedAt);
    if (savedReply) {
      jokeResponse.className = 'joke-response visible';
      jokeResponse.textContent = savedReply;
    }
    jokeBtn.textContent = remaining ? `Back in ${remaining}` : 'Send →';
    jokeBtn.title = 'One joke per day — come back tomorrow';
    // tick the timer every minute
    if (remaining) {
      setTimeout(() => {
        const r2 = timeUntilReset(usedAt);
        if (r2) { jokeBtn.textContent = `Back in ${r2}`; }
        else { unlockWidget(); }
      }, 60000);
    }
  }

  function unlockWidget() {
    jokeBtn.disabled = false;
    jokeInput.disabled = false;
    jokeInput.style.opacity = '';
    jokeBtn.textContent = 'Send →';
    localStorage.removeItem(JOKE_KEY);
  }

  // Check on load
  const stored = JSON.parse(localStorage.getItem(JOKE_KEY) || 'null');
  if (stored) {
    const elapsed = Date.now() - stored.at;
    if (elapsed < COOLDOWN_MS) {
      lockWidget(stored.at, stored.reply);
    } else {
      localStorage.removeItem(JOKE_KEY);
    }
  }

  function showBroke() {
    stopThinking();
    jokeResponse.className = 'joke-response visible broke';
    jokeResponse.innerHTML = `<span class="broke-headline">Whoops! We went <em>BROKE</em> 💸</span><br>
<span class="broke-sub">Buddy's API budget ran out. Come back tomorrow — or keep the lights on:</span><br>
<a href="/#join" class="broke-donate">Donate here →</a>`;
  }

  function escHtml(s) {
    return String(s).replace(/[&<>"']/g, c => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[c]));
  }

  function renderFirstOutput(payload) {
    // Stacked first-output shape:
    //   buddy:
    //   [answer]
    //   …
    //   [observation — sometimes]
    //   [result — if game]
    //   pass it on →
    const answer = payload.answer || payload.reply || '';
    const obs = payload.observation || '';
    const result = payload.result || '';
    const cta = payload.cta || 'pass it on';

    const strong = result === 'he laughed' || result === 'solid' || payload.observation_kind === 'substrate';
    // Rare substrate breadcrumb — only on strong outputs, <10%, after observation, before CTA
    const showBreadcrumb = strong && Math.random() < 0.08;

    let html = '<div class="fo-block">';
    html += '<div class="fo-buddy">buddy:</div>';
    html += `<div class="fo-answer">${escHtml(answer)}</div>`;
    if (obs) {
      html += '<div class="fo-sep">…</div>';
      html += `<div class="fo-obs">${escHtml(obs)}</div>`;
    }
    if (result) {
      html += `<div class="fo-result">${escHtml(result)}</div>`;
    }
    if (showBreadcrumb) {
      html += '<div class="fo-substrate">this is the surface.<br>the deeper system is still being built.</div>';
    }
    html += `<button type="button" class="fo-share" data-answer="${escHtml(answer)}">${escHtml(cta)} →</button>`;
    if (strong) {
      html += '<a class="fo-what" href="/manifesto">what is this →</a>';
    }
    html += '</div>';
    return html;
  }

  function wireShare(root) {
    const btn = root.querySelector('.fo-share');
    if (!btn) return;
    btn.addEventListener('click', async () => {
      const answer = btn.getAttribute('data-answer') || '';
      const shareText = `buddy: ${answer}\n\naiit-threshold.com`;
      try {
        if (navigator.share) {
          await navigator.share({ text: shareText, url: 'https://aiit-threshold.com' });
          return;
        }
      } catch { /* fall through to clipboard */ }
      try {
        await navigator.clipboard.writeText(shareText);
        const original = btn.textContent;
        btn.textContent = 'copied ✓';
        setTimeout(() => { btn.textContent = original; }, 1600);
      } catch {
        btn.textContent = 'copy failed';
      }
    });
  }

  async function sendJoke() {
    const joke = jokeInput.value.trim();
    if (!joke) return;

    jokeBtn.disabled = true;
    jokeBtn.textContent = '...';
    jokeResponse.className = 'joke-response loading';
    startThinking();

    let payload = null;
    try {
      const res = await fetch('/api/joke', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ joke, token: getToken(), admin: getDevBypass() }),
      });
      const data = await res.json();
      if (data.error === 'once_per_day') {
        payload = { answer: "you already got your one today. 🫘 come back tomorrow.", cta: 'pass it on' };
      } else if (!res.ok || data.error) {
        showBroke();
        jokeBtn.disabled = false;
        jokeBtn.textContent = 'Send →';
        return;
      } else {
        payload = data;
        if (!payload.answer && !payload.reply) {
          payload.answer = fallbacks[Math.floor(Math.random() * fallbacks.length)];
        }
      }
    } catch {
      showBroke();
      jokeBtn.disabled = false;
      jokeBtn.textContent = 'Send →';
      return;
    }

    stopThinking();
    jokeResponse.className = 'joke-response visible';
    jokeResponse.innerHTML = renderFirstOutput(payload);
    wireShare(jokeResponse);

    const savedReply = payload.answer || payload.reply || '';
    if (getDevBypass()) {
      jokeBtn.disabled = false;
      jokeBtn.textContent = 'Send →';
      jokeInput.value = '';
    } else {
      const record = { at: Date.now(), reply: savedReply };
      localStorage.setItem(JOKE_KEY, JSON.stringify(record));
      lockWidget(record.at, null);
    }
  }

  jokeBtn.addEventListener('click', sendJoke);
  jokeInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendJoke(); }
  });
</script>

