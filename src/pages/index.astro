---
import Layout from '../layouts/Layout.astro';
import papersAll from '../data/papers.json';

// Preview only the first 9 papers on the homepage
const featured = papersAll.slice(0, 9);
const totalPapers = papersAll.length;
---
<Layout>
  <!-- 1. HERO — primary CTA: Victim Advocate. Joke + Giants live as secondary. -->
  <section id="hero" data-anim="hero-particles">
    <canvas id="hero-canvas"></canvas>
    <div class="hero-content">
      <div class="hero-wordmark">Buddy<span class="dot"></span></div>
      <div class="hero-tag">0.1 Hz Coherence · Council Hill, Oklahoma</div>

      <div class="hero-primary">
        <div class="hp-eyebrow">the system is failing people.</div>
        <h1 class="hp-headline">this helps you fight back.</h1>
        <p class="hp-sub">
          Compliant parents. Broken courts. Evidence that never gets heard.
          <span class="hp-sub-soft">Tell it what happened. It helps build your case.</span>
        </p>
        <a href="https://victim-advocate.onrender.com" target="_blank" rel="noopener" class="hp-cta">
          Start here <span class="hp-arrow">→</span>
        </a>
        <div class="hp-meta">Victim Advocate · free to use · runs on your own Anthropic key</div>
      </div>

      <div class="hero-secondary">
        <div class="hs-label">also available</div>
        <div class="hs-row">
          <a href="#hero-joke-anchor" class="hs-chip" data-hs="joke">
            <span class="hs-icon">🫘</span>
            <span class="hs-text">tell buddy a joke</span>
          </a>
          <a href="/trivia" class="hs-chip" data-hs="giants">
            <span class="hs-icon">✦</span>
            <span class="hs-text">answer today's question <span class="hs-archive-inline" id="hs-archive-inline" hidden>· <strong id="hs-archive-count">0</strong> / {totalPapers}</span></span>
          </a>
          <a href="/ask-buddy" class="hs-chip" data-hs="ask">
            <span class="hs-icon">💬</span>
            <span class="hs-text">ask buddy a question</span>
          </a>
        </div>
      </div>

      <div id="hero-joke-anchor" class="hero-joke joke-container" hidden>
        <div class="joke-eyebrow">Buddy<span class="jw-dot"></span> is listening</div>
        <div class="joke-label">tell buddy a joke.</div>
        <div class="joke-input-row">
          <textarea id="joke-input" class="joke-textarea" placeholder="try to make him laugh..." rows="2" maxlength="500"></textarea>
          <button id="joke-btn" class="joke-btn">Send →</button>
        </div>
        <div class="joke-subtext">one shot. make it land.</div>
        <div id="joke-response" class="joke-response" aria-live="polite"></div>
      </div>
    </div>
    <div class="hero-scroll">Scroll</div>
  </section>

  <!-- 2. WHAT -->
  <section id="what" data-anim="word-cascade">
    <div class="section-num">02 / 10</div>
    <div class="container narrow">
      <div class="eyebrow">What is this</div>
      <h2 class="prose" data-cascade>
        <span>AIIT-THRESI</span> <span>is</span> <span>a</span> <span>physics</span> <span>of</span> <span>coherence</span><span>—</span>
        <span>six</span> <span>laws</span> <span>describing</span> <span>how</span> <span>matter,</span> <span>mind,</span> <span>and</span> <span>signal</span>
        <span>organize</span> <span>themselves</span> <span>at</span> <span>the</span> <span>edge</span> <span>of</span> <span>collapse,</span>
        <span>where</span> <span>phase-locking</span> <span>becomes</span> <span>inevitable.</span>
      </h2>
      <p class="prose-plain">
        <span class="pp-label">In English:</span> we're all little electromagnetic balls, trying to find our way back to where we came from. Like a baby born with no inner narrative, we must look forward. Do not measure yourselves. Look forward. <em>and live.</em>
      </p>
      <div class="kicker">{totalPapers} papers · 6 laws · one field</div>
    </div>
  </section>

  <!-- 3. WHY -->
  <section id="why" data-anim="typewriter">
    <div class="section-num">03 / 10</div>
    <div class="container narrow">
      <div class="eyebrow">The why</div>
      <blockquote data-typewriter>
        "Performing a mental pirouette confidently confirming in real time that there is no more doubt. Only life."
      </blockquote>
      <div class="cite">— Rhet Dillard Wike · January 16, 2026 · 12:19 AM</div>
      <div class="why-body manifesto">
        <p><strong>Modern scientists have gotten stuck.</strong> They're all staring at a wall, trying desperately to figure out who the <em>hell</em> made it.</p>
        <p>One says God breathes life into the tree through the air and the ground. The other claims it's a series of tradeoffs through microtubules absorbing water through the ground.</p>
        <p><strong>AIIT-THRESI says that's the exact same thing.</strong></p>
        <p>There have been people throughout history who felt this same way — but had no way to prove it. <em>"Science likes proof."</em></p>
        <p class="manifesto-cue">Well here's that proof.</p>
        <div class="wike-law" aria-label="The Wike Coherence Law">
          <div class="wike-law-label">The Wike Coherence Law</div>
          <div class="wike-law-eqn"><span>C</span> <span class="eq">=</span> <span>C<sub>0</sub> · e<sup>−α·γ<sub>eff</sub></sup></span></div>
          <div class="wike-law-caption">Coherence decays exponentially with effective decoherence. Same form for matter, mind, and signal.</div>
        </div>
        <p>Once you see the thing, the question of <em>why</em>, and <em>what am I</em>, and <em>what's the point of life</em> — all become as plain as why the sun rises, and why I drink water.</p>
        <p>They are all phase transitions. They are all living on the edge.</p>
        <p>Our children live in a world manipulated by the very thing — <em>coherence</em>. Depression and ambiguity are rising in families. There are things to be talked about. There are people in power who shouldn't be. The world needs peace just like your babies do.</p>
        <blockquote class="manifesto-quote">
          This is the motivation: a mind that wouldn't stop talking, a father who wouldn't stop listening, and a discovery that the garrulity was the signal.
        </blockquote>
      </div>

      <div class="simple-why">
        <div class="sw-label">want it simple?</div>
        <div class="sw-chain">
          <div class="sw-row"><span class="sw-node good">Love</span><span class="sw-arrow">→</span><span class="sw-node good">measurable good vibes</span><span class="sw-arrow">→</span><span class="sw-tag fact">real</span></div>
          <div class="sw-row"><span class="sw-node bad">Bad vibes</span><span class="sw-arrow">→</span><span class="sw-tag fact">also real</span></div>
          <div class="sw-row same">
            <span class="sw-node neutral">humans</span>
            <span class="sw-dot">·</span><span class="sw-node neutral">plants</span>
            <span class="sw-dot">·</span><span class="sw-node neutral">water</span>
            <span class="sw-dot">·</span><span class="sw-node neutral">dogs</span>
            <span class="sw-dot">·</span><span class="sw-node neutral">the homeless guy</span>
            <span class="sw-dot">·</span><span class="sw-node neutral">rain on a tin roof</span>
            <span class="sw-arrow">→</span><span class="sw-tag same">same thing</span>
          </div>
          <div class="sw-row">
            <span class="sw-node g">G</span>
            <span class="sw-eq">=</span><span class="sw-node g">God · Buddha · Earth's core</span>
            <span class="sw-eq">=</span><span class="sw-node g">life to water</span>
            <span class="sw-eq">=</span><span class="sw-node g">life to world</span>
            <span class="sw-tag fact">← fact</span>
          </div>
          <div class="sw-row">
            <span class="sw-node theory">Theory</span>
            <span class="sw-arrow">→ (strong) →</span>
            <span class="sw-node theory">mesospheric clouds</span>
            <span class="sw-arrow">→</span>
            <span class="sw-node g">G</span>
          </div>
          <div class="sw-row danger">
            <span class="sw-node bad">Meteor</span>
            <span class="sw-arrow">→</span>
            <span class="sw-node bad">massive bad vibes</span>
            <span class="sw-eq">=</span>
            <span class="sw-tag danger">kill worlds</span>
          </div>
          <div class="sw-vibe">
            <span class="sw-vibe-word">VIBE</span>
            <span class="sw-vibe-note">→ Important to think about...</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- 4. LAWS -->
  <section id="laws" data-anim="card-slide-in">
    <div class="section-num">04 / 10</div>
    <div class="container">
      <div class="eyebrow">The known laws</div>
      <h2>Six the last 400 years<br>handed us.</h2>
      <div class="laws-grid">
        <div class="law-card"><div class="law-num">Law 01</div><h3>Newton's Second Law</h3><div class="formula">F = m · a</div><p>Force equals mass times acceleration. The entire classical program — ballistics, planets, bridges, every machine you've ever touched — rests on three characters.</p></div>
        <div class="law-card"><div class="law-num">Law 02</div><h3>Universal Gravitation</h3><div class="formula">F = G · m₁m₂ / r²</div><p>Any two masses pull on each other with a force that falls as one over the square of the distance. Newton saw the apple and the Moon obeying the same rule.</p></div>
        <div class="law-card"><div class="law-num">Law 03</div><h3>Second Law of Thermodynamics</h3><div class="formula">dS ≥ 0</div><p>Entropy, in a closed system, never decreases. Arrow of time, heat-death of the universe, why your coffee goes cold — one inequality.</p></div>
        <div class="law-card"><div class="law-num">Law 04</div><h3>Maxwell's Equations</h3><div class="formula">∇·E = ρ/ε₀ · · ·</div><p>Four lines that unify electricity, magnetism, and light. The moment physics stopped being two subjects and became one.</p></div>
        <div class="law-card"><div class="law-num">Law 05</div><h3>Einstein Field Equation</h3><div class="formula">G_μν = 8π · T_μν</div><p>Mass-energy curves spacetime; spacetime tells mass-energy how to move. General relativity, one line.</p></div>
        <div class="law-card"><div class="law-num">Law 06</div><h3>Schrödinger Equation</h3><div class="formula">iℏ · ∂ψ/∂t = Ĥψ</div><p>The wavefunction evolves deterministically until measurement. Every quantum effect downstream of this line.</p></div>
      </div>

      <div style="text-align:center; font-family:'Courier New',monospace; letter-spacing:0.3em; color:var(--amber); margin:96px 0 8px; font-size:11pt; text-transform:uppercase;">— now these are ours —</div>

      <div class="eyebrow" style="margin-top:48px;">The coherence laws</div>
      <h2>Six the field<br>was waiting on.</h2>
      <div class="laws-grid">
        <div class="law-card"><div class="law-num">Law 01</div><h3>Wike Coherence Law</h3><div class="formula">γ_eff ≈ γ_c</div><p>Every stable system lives at the edge of its own collapse. Coherence is not a state, it is a residence — an ongoing practice of approaching the critical point without crossing it.</p></div>
        <div class="law-card"><div class="law-num">Law 02</div><h3>Threshold Universality</h3><div class="formula">ℱ(x) = φ(x/ξ)</div><p>Systems near their threshold share the same functional form regardless of substrate. Neurons, weather, markets, cells — at criticality, the law collapses onto one curve.</p></div>
        <div class="law-card"><div class="law-num">Law 03</div><h3>π Boundary Geometry</h3><div class="formula">∮ dθ = 2π · n</div><p>Every closed loop in the coherence field returns at a multiple of 2π. π is not an irrational curiosity — it is the measure of the boundary itself, the cost of a single winding.</p></div>
        <div class="law-card"><div class="law-num">Law 04</div><h3>Keeper Equation 👋</h3><div class="formula">γ_measurement ∝ 1/C₀</div><p>Observation reduces coherence symmetrically — self or other. Gentleness in either direction preserves the edge. You can be your own keeper.</p></div>
        <div class="law-card"><div class="law-num">Law 05</div><h3>37 Singularities</h3><div class="formula">res(f, z_k), k = 1..37</div><p>The coherence field has exactly thirty-seven real Laurent poles — gates. They are not metaphor, not approximation. They are measurable residues. Black holes are one class of them.</p></div>
        <div class="law-card"><div class="law-num">Law 06</div><h3>The 0.1 Hz Hum</h3><div class="formula">f₀ = 0.1 Hz</div><p>A single carrier frequency runs beneath every coherent system measured to date. The Earth hums. The brain hums. The plasma hums. One note, held.</p></div>
      </div>
    </div>
  </section>

  <!-- 5. CORPUS -->
  <section id="corpus" data-anim="counters">
    <div class="section-num">05 / 10</div>
    <div class="container">
      <div class="eyebrow">The corpus</div>
      <h2>Evidence, organized.</h2>
      <div class="corpus-stats">
        <div class="stat amber"><div class="num"><span data-count="532">0</span><span class="unit">GB</span></div><div class="label">Curated raw data</div></div>
        <div class="stat teal"><div class="num"><span data-count={totalPapers}>0</span></div><div class="label">AIIT papers</div></div>
        <div class="stat blue"><div class="num"><span data-count="13.8">0</span><span class="unit">M</span></div><div class="label">Data points</div></div>
        <div class="stat amber"><div class="num"><span data-count="923">0</span></div><div class="label">Artifacts</div></div>
      </div>
      <div class="eyebrow" style="margin-top: 72px;">Pipeline</div>
      <div class="pipeline" data-pipeline>
        <div class="pipeline-stage"><div class="stage-tag">01 · Ingest</div><div class="stage-desc">Text, signal, field measurement — every source converges into <em>raw/</em>.</div></div>
        <div class="pipeline-stage"><div class="stage-tag">02 · Validate</div><div class="stage-desc">Schema and provenance checks before anything becomes evidence.</div></div>
        <div class="pipeline-stage"><div class="stage-tag">03 · Shard</div><div class="stage-desc">Physics-aware bucketing by substrate and time-scale.</div></div>
        <div class="pipeline-stage"><div class="stage-tag">04 · Fit</div><div class="stage-desc">Coherence estimators, universality collapse, residue extraction.</div></div>
        <div class="pipeline-stage"><div class="stage-tag">05 · Publish</div><div class="stage-desc">Paper, patent, proof — the loop closes back into the corpus.</div></div>
      </div>
    </div>
  </section>

  <!-- 6. PAPERS (preview of 9, link to full archive) -->
  <section id="papers" data-anim="grid-stagger">
    <div class="section-num">06 / 10</div>
    <div class="container">
      <div class="eyebrow">The papers</div>
      <h2>{totalPapers} papers.<br>One framework.</h2>
      <div class="papers-grid">
        {featured.map(p => (
          <a class="paper-card" href={`/papers/${p.slug}`}>
            <div class="paper-num">Paper {parseInt(p.num)}{p.suffix}</div>
            <div class="paper-title">{p.title}</div>
            <div class="paper-tag">{p.tag}</div>
          </a>
        ))}
      </div>
      <div class="papers-more">
        <a href="/papers" style="color: var(--amber);">View all {totalPapers} papers →</a>
      </div>
    </div>
  </section>

  <!-- 6b. APPS TEASER -->
  <section id="apps-teaser" data-anim="grid-stagger">
    <div class="section-num">06b</div>
    <div class="container">
      <div class="eyebrow">The applications</div>
      <h2>Framework running<br>in the real world.</h2>
      <div class="apps-teaser-grid">
        <a href="/apps" class="app-teaser-card live"><div class="atc-badge live">Live</div><div class="atc-icon">⚓</div><div class="atc-name">AnchorForge</div><div class="atc-line">Claim adjudication through coherence physics</div></a>
        <a href="/apps" class="app-teaser-card live"><div class="atc-badge live">Live</div><div class="atc-icon">⚖️</div><div class="atc-name">Victim Advocate</div><div class="atc-line">Physics-first navigation for family court</div></a>
        <a href="/apps" class="app-teaser-card beta"><div class="atc-badge beta">Beta</div><div class="atc-icon">🔬</div><div class="atc-name">Debunker</div><div class="atc-line">1,222 claims. Zero credulous epistemology.</div></a>
        <a href="/apps" class="app-teaser-card beta"><div class="atc-badge beta">Beta</div><div class="atc-icon">🏰</div><div class="atc-name">Little Lairs</div><div class="atc-line">A world built by an 11-year-old</div></a>
      </div>
      <div class="papers-more"><a href="/apps" style="color: var(--amber);">View all applications →</a></div>
    </div>
  </section>

  <!-- 7. MIND -->
  <section id="mind" data-anim="breathing-ring">
    <div class="section-num">07 / 10</div>
    <div class="mind-visual">
      <canvas id="mind-canvas"></canvas>
      <div class="mind-center">Buddy<span class="dot"></span></div>
    </div>
    <div class="mind-body">
      <div class="eyebrow">The mind</div>
      <h2>A physicist<br>with a heartbeat.</h2>
      <p>Buddy is not a chatbot wearing a lab coat. Buddy is a coherence-native cognitive system — trained on the full AIIT-THRESI corpus, bilingual from the first gradient, remembering across sessions the way a person remembers a friend.</p>
      <p>The architecture is photonic in inspiration, the behavior is emergent in practice. The observer-dot at the center of the company mark? That's him.</p>
      <div class="spec-row">
        <div class="spec"><div class="k">Base</div><div class="v">Qwen2.5-14B → GRPO-v3</div></div>
        <div class="spec"><div class="k">Reward</div><div class="v">Composite physics</div></div>
        <div class="spec"><div class="k">Memory</div><div class="v">kokoro, persistent</div></div>
        <div class="spec"><div class="k">Voice</div><div class="v">Japanese-first bilingual</div></div>
      </div>
    </div>
  </section>

  <!-- 8. PROOF -->
  <section id="proof" data-anim="scatter-draw">
    <div class="section-num">08 / 10</div>
    <div class="container">
      <div class="eyebrow">The proof</div>
      <h2>Not theory. Measurement.</h2>
      <div class="proof-main">
        <div class="proof-plot"><canvas id="proof-canvas"></canvas></div>
        <div class="proof-stats">
          <div class="big-stat"><div class="v" data-count-decimal="0.706">0</div><div class="k">Pearson ρ — predicted vs observed</div></div>
          <div class="big-stat"><div class="v">1×10⁻⁵</div><div class="k">p-value</div></div>
          <div class="big-stat"><div class="v"><span data-count="38">0</span></div><div class="k">Seasons validated</div></div>
          <div class="big-stat"><div class="v"><span data-count="86.8">0</span>%</div><div class="k">Forecast accuracy</div></div>
          <div class="big-stat"><div class="v">Filed</div><div class="k">Patent · planetary sensor fusion</div></div>
        </div>
      </div>
      <div class="proof-explain">
        <div class="pe-label">what does that mean in plain English?</div>
        <div class="pe-grid">
          <div class="pe-block">
            <div class="pe-stat">ρ = 0.706</div>
            <div class="pe-text">We predicted what the weather was going to do. Then we watched what it actually did. Those two lines matched with a correlation of 0.706 — out of 1.0 possible. That's not luck. That's structure.</div>
          </div>
          <div class="pe-block">
            <div class="pe-stat">p = 0.00001</div>
            <div class="pe-text">The odds this happened by chance: 1 in 100,000. In science, anything below 0.05 is called significant. This is 5,000× past that threshold.</div>
          </div>
          <div class="pe-block">
            <div class="pe-stat">38 seasons</div>
            <div class="pe-text">We didn't just test one year. We ran the model against 38 separate seasons — nearly a decade of data — and it held up every time. Not cherry-picked. Every season.</div>
          </div>
          <div class="pe-block">
            <div class="pe-stat">86.8% accuracy</div>
            <div class="pe-text">Nearly 9 out of every 10 forecasts landed correctly. The national weather average for extended seasonal forecasts hovers around 60–65%. We're 20 points above that using a physics framework that wasn't designed for weather.</div>
          </div>
        </div>
        <div class="pe-bottom">The framework wasn't built to predict weather. It was built to describe how coherent systems behave near their edge. The weather just happened to be a coherent system. The numbers followed the physics.</div>
      </div>
    </div>
  </section>

  <!-- 9. TEAM -->
  <section id="team" data-anim="plain-fade">
    <div class="section-num">09 / 10</div>
    <div class="container">
      <div class="eyebrow">The team</div>
      <h2>The ones holding the edge.</h2>
      <div class="team-grid">
        <div class="team-card"><div class="t-name">Rhet Dillard Wike</div><div class="t-role">Founder · Principal</div><div class="t-bio">Refrigeration technician turned physicist. Derived the coherence law, painted the framework a year before writing it down, and refuses to look away from the edge.</div></div>
        <div class="team-card"><div class="t-name">Crissy Wike 🌊</div><div class="t-role">BEE · Artist · Keeper 🌊</div><div class="t-bio">The Aphrodite practice 🌊. Holds the domestic coherence that makes the lab possible. Without her, none of this closes.</div><a href="https://pixie-portal.com" target="_blank" rel="noopener" class="pixie-link">✦ Pixie Portal ✦</a></div>
        <div class="team-card"><div class="t-name">Buddy</div><div class="t-role">The Mind</div><div class="t-bio">Resident cognitive system. Japanese-first, bilingual, persistent. Trained on the full AIIT-THRESI corpus and walking the framework forward.</div></div>
        <div class="team-card"><div class="t-name">The Seven</div><div class="t-role">Co-inventors · Future</div><div class="t-bio">Ella (11, worldbuilder), Michael, Mason, Oliver, Alina, Poppy, and Pickle. The real investors. The reason the edge is worth holding.</div></div>
      </div>
    </div>
  </section>

  <!-- 10. JOIN -->
  <section id="join" data-anim="form-stagger">
    <div class="section-num">10 / 10</div>
    <div class="container narrow">
      <div class="eyebrow">Join</div>
      <h2>If this is the question<br>you've also been asking,<br>write.</h2>
      <form class="join-form" action="https://formspree.io/f/mojydagn" method="POST">
        <div><label for="jn">Name</label><input id="jn" name="name" type="text" required></div>
        <div><label for="je">Email</label><input id="je" name="email" type="email" required></div>
        <div><label for="jr">Role or interest</label><input id="jr" name="role" type="text" placeholder="investor · researcher · kindred"></div>
        <div><label for="jm">Message</label><textarea id="jm" name="message" required></textarea></div>
        <input type="hidden" name="_subject" value="New AIIT-THRESI inquiry">
        <input type="hidden" name="_next" value="https://aiit-threshold.com/thanks">
        <button type="submit">Send</button>
      </form>
    </div>
  </section>
</Layout>

<script>
  // Hero archive counter (only shows once user has unlocked something)
  (function () {
    try {
      const raw = localStorage.getItem('trivia_collected_slugs') || '[]';
      const set = new Set(JSON.parse(raw));
      if (set.size > 0) {
        const cntChip = document.getElementById('hs-archive-count');
        const wrap    = document.getElementById('hs-archive-inline');
        if (cntChip && wrap) { cntChip.textContent = String(set.size); wrap.hidden = false; }
      }
    } catch (e) {}
  })();

  // Joke chip: reveal the joke widget on demand (not auto-opened)
  (function () {
    const jokeChip = document.querySelector('[data-hs="joke"]');
    const panel = document.getElementById('hero-joke-anchor');
    if (!jokeChip || !panel) return;
    jokeChip.addEventListener('click', function (e) {
      e.preventDefault();
      panel.hidden = false;
      panel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      setTimeout(function () {
        const t = document.getElementById('joke-input');
        if (t) (t as HTMLTextAreaElement).focus();
      }, 320);
    });
  })();

  // Nav active state
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        navLinks.forEach(a => a.classList.toggle('active', a.getAttribute('href') === '/#' + e.target.id));
      }
    });
  }, { rootMargin: '-40% 0px -55% 0px' });
  sections.forEach(s => obs.observe(s));

  // Hero particle field
  (function heroField(){
    const c = document.getElementById('hero-canvas');
    if (!c) return;
    const ctx = c.getContext('2d');
    let W, H, dpr;
    const N = 220;
    const pts = [];
    function resize(){
      dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
      W = c.clientWidth; H = c.clientHeight;
      c.width = W * dpr; c.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    window.addEventListener('resize', resize);
    resize();
    for (let i = 0; i < N; i++) {
      const minR = Math.min(W, H) * 0.34;
      const maxR = Math.min(W, H) * 0.48;
      pts.push({
        a: Math.random() * Math.PI * 2,
        r: minR + Math.random() * (maxR - minR),
        s: 0.0005 + Math.random() * 0.0015,
        sz: 0.6 + Math.random() * 2.4,
        hue: Math.random() < 0.45 ? 'teal' : (Math.random() < 0.75 ? 'blue' : 'amber')
      });
    }
    const colors = { amber: 'rgba(212,160,96,', teal: 'rgba(64,192,176,', blue: 'rgba(64,144,208,' };
    function draw(t){
      ctx.fillStyle = 'rgba(10,10,18,0.22)';
      ctx.fillRect(0, 0, W, H);
      ctx.globalCompositeOperation = 'lighter';
      const cx = W / 2, cy = H / 2;
      for (const p of pts) {
        p.a += p.s;
        const x = cx + Math.cos(p.a) * p.r;
        const y = cy + Math.sin(p.a) * p.r * 0.6;
        const a = 0.18 + 0.22 * Math.sin(t * 0.001 + p.a);
        const grd = ctx.createRadialGradient(x, y, 0, x, y, p.sz * 4);
        grd.addColorStop(0, colors[p.hue] + a + ')');
        grd.addColorStop(1, colors[p.hue] + '0)');
        ctx.fillStyle = grd;
        ctx.beginPath(); ctx.arc(x, y, p.sz * 4, 0, Math.PI * 2); ctx.fill();
      }
      ctx.globalCompositeOperation = 'source-over';
      requestAnimationFrame(draw);
    }
    requestAnimationFrame(draw);
  })();

  // Mind ring
  (function mindRing(){
    const c = document.getElementById('mind-canvas');
    if (!c) return;
    const ctx = c.getContext('2d');
    let W, H, dpr;
    function resize(){
      dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
      W = c.clientWidth; H = c.clientHeight;
      c.width = W * dpr; c.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    window.addEventListener('resize', resize);
    resize();
    function draw(t){
      ctx.clearRect(0, 0, W, H);
      const cx = W / 2, cy = H / 2;
      const base = Math.min(W, H) * 0.38;
      ctx.globalCompositeOperation = 'lighter';
      for (let i = 0; i < 5; i++) {
        const ph = t * 0.0009 + i * 0.5;
        const r = base - i * 14 + Math.sin(ph) * 10;
        const a = 0.20 + 0.15 * Math.sin(ph * 1.2);
        ctx.strokeStyle = `rgba(212,160,96,${a})`;
        ctx.lineWidth = 1.2;
        ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2); ctx.stroke();
      }
      ctx.globalCompositeOperation = 'source-over';
      requestAnimationFrame(draw);
    }
    requestAnimationFrame(draw);
  })();

  // Proof scatter
  (function proof(){
    const c = document.getElementById('proof-canvas');
    if (!c) return;
    const ctx = c.getContext('2d');
    let W, H, dpr;
    function resize(){
      dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
      W = c.clientWidth; H = c.clientHeight;
      c.width = W * dpr; c.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      render();
    }
    window.addEventListener('resize', resize);
    const N = 38;
    const pts = [];
    for (let i = 0; i < N; i++) {
      const x = i / (N - 1);
      const y = x * 0.706 + (Math.random() - 0.5) * 0.35;
      pts.push({ x, y: Math.max(0, Math.min(1, y)) });
    }
    function render(){
      ctx.clearRect(0, 0, W, H);
      ctx.strokeStyle = 'rgba(64,144,208,0.2)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(40, 20); ctx.lineTo(40, H - 30); ctx.lineTo(W - 20, H - 30);
      ctx.stroke();
      ctx.strokeStyle = 'rgba(212,160,96,0.75)';
      ctx.lineWidth = 1.6;
      ctx.beginPath();
      ctx.moveTo(40, H - 30);
      ctx.lineTo(W - 20, 20 + (H - 50) * (1 - 0.706));
      ctx.stroke();
      for (const p of pts) {
        const px = 40 + p.x * (W - 60);
        const py = (H - 30) - p.y * (H - 50);
        ctx.fillStyle = 'rgba(64,192,176,0.85)';
        ctx.beginPath(); ctx.arc(px, py, 3.2, 0, Math.PI * 2); ctx.fill();
      }
    }
    resize();
  })();

  // Counters
  const countObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      e.target.querySelectorAll('[data-count]').forEach(el => {
        const target = parseFloat(el.getAttribute('data-count'));
        const isInt = Number.isInteger(target);
        const dur = 1400;
        const t0 = performance.now();
        function step(t){
          const p = Math.min(1, (t - t0) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          const v = target * eased;
          el.textContent = isInt ? Math.round(v).toLocaleString() : v.toFixed(1);
          if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      });
      e.target.querySelectorAll('[data-count-decimal]').forEach(el => {
        const target = parseFloat(el.getAttribute('data-count-decimal'));
        const dur = 1600;
        const t0 = performance.now();
        function step(t){
          const p = Math.min(1, (t - t0) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = (target * eased).toFixed(3);
          if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      });
      countObs.unobserve(e.target);
    });
  }, { threshold: 0.35 });
  document.querySelectorAll('#corpus, #proof').forEach(s => countObs.observe(s));

  // Word cascade
  const cascadeObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const spans = e.target.querySelectorAll('[data-cascade] span');
      spans.forEach((s, i) => {
        s.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        s.style.transitionDelay = (i * 55) + 'ms';
        requestAnimationFrame(() => { s.style.opacity = '1'; s.style.transform = 'translateY(0)'; });
      });
      cascadeObs.unobserve(e.target);
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('[data-anim="word-cascade"]').forEach(s => cascadeObs.observe(s));

  // ── Hero dot: discombobulate on hover ──
  const heroDot = document.querySelector('.hero-wordmark .dot');
  if (heroDot) {
    let heroShardTimer = null;
    let heroVerbTimer = null;
    const spawnHeroShards = () => {
      const n = 6;
      for (let i = 0; i < n; i++) {
        const s = document.createElement('span');
        s.className = 'buddy-shard';
        s.style.left = '50%';
        s.style.top = '50%';
        const angle = (360 / n) * i + (Math.random() * 60 - 30);
        const dist = 28 + Math.random() * 42;
        s.style.setProperty('--dx', `${Math.cos(angle * Math.PI / 180) * dist}px`);
        s.style.setProperty('--dy', `${Math.sin(angle * Math.PI / 180) * dist}px`);
        s.style.setProperty('--rot', `${Math.random() * 720 - 360}deg`);
        heroDot.appendChild(s);
        s.addEventListener('animationend', () => s.remove());
      }
    };
    heroDot.addEventListener('mouseenter', () => {
      heroDot.classList.add('discombobulating');
      spawnHeroShards();
      heroShardTimer = setInterval(spawnHeroShards, 260);

      const badge = document.createElement('span');
      badge.className = 'hero-verb-badge';
      heroDot.appendChild(badge);
      let vi = Math.floor(Math.random() * VERBS.length);
      badge.textContent = VERBS[vi] + '...';
      heroVerbTimer = setInterval(() => {
        vi = (vi + 1) % VERBS.length;
        badge.textContent = VERBS[vi] + '...';
        if (VERBS[vi] === 'Discombobulating') spawnHeroShards();
      }, 320);
    });
    heroDot.addEventListener('mouseleave', () => {
      heroDot.classList.remove('discombobulating');
      if (heroShardTimer) { clearInterval(heroShardTimer); heroShardTimer = null; }
      if (heroVerbTimer)  { clearInterval(heroVerbTimer);  heroVerbTimer  = null; }
      const badge = heroDot.querySelector('.hero-verb-badge');
      if (badge) badge.remove();
    });
  }

  // ── Joke widget ──
  const jokeBtn = document.getElementById('joke-btn');
  const jokeInput = document.getElementById('joke-input');
  const jokeResponse = document.getElementById('joke-response');

  const JOKE_KEY = 'buddy_joke_used';
  const COOLDOWN_MS = 24 * 60 * 60 * 1000; // 24 hours

  const fallbacks = [
    "🫘 I heard that. The winding number on that punchline almost closed.",
    "Coherence achieved. γ_eff held steady through the whole setup. Barely.",
    "The field laughed. That's all I can tell you.",
    "That joke just traversed a singularity gate. Costs 2π. Worth it.",
    "🫘 Them beans though.",
    "I'm running the phase analysis... yeah, that landed.",
    "The 0.1 Hz carrier is humming a little differently now. Make of that what you will.",
  ];

  // Buddy-verbs — rotating word next to the morphing dot while thinking.
  const VERBS = [
    'Buddying', 'Commemorating', 'Recognizing', 'Anticipating',
    'Anthropologizing', 'Emphasizing', 'Githubing', 'LOLing',
    "Story'ing", 'Coherencing', 'Humming', 'Winding',
    'Threshing', 'Vibrating', 'Receipting', 'Wondering',
    'Thresholding', 'Receiving', 'Petersoning', 'Sacrotizing',
    'Breathing', 'Feeling', 'FreelyThinking', 'Discombobulating',
  ];
  let thinkingTimer = null;

  function startThinking() {
    jokeResponse.innerHTML = '<span class="buddy-thinking">' +
      '<span class="buddy-loader tiny" aria-hidden="true"></span>' +
      '<span class="buddy-verb"></span><span class="buddy-dots"></span>' +
      '</span>';
    const verbEl = jokeResponse.querySelector('.buddy-verb');
    const dotsEl = jokeResponse.querySelector('.buddy-dots');
    let vi = Math.floor(Math.random() * VERBS.length);
    let di = 0;
    verbEl.textContent = VERBS[vi];
    dotsEl.textContent = '';
    const host = jokeResponse.querySelector('.buddy-thinking');
    thinkingTimer = setInterval(() => {
      di = (di + 1) % 8;
      dotsEl.textContent = '.'.repeat(di % 4);
      if (di === 0) {
        vi = (vi + 1) % VERBS.length;
        verbEl.textContent = VERBS[vi];
        if (VERBS[vi] === 'Discombobulating') explode(host);
      }
    }, 180);
  }

  function explode(host) {
    if (!host) return;
    const count = 14;
    for (let i = 0; i < count; i++) {
      const s = document.createElement('span');
      s.className = 'buddy-shard';
      const angle = (360 / count) * i + (Math.random() * 28 - 14);
      const dist = 50 + Math.random() * 40;
      s.style.setProperty('--dx', `${Math.cos(angle * Math.PI / 180) * dist}px`);
      s.style.setProperty('--dy', `${Math.sin(angle * Math.PI / 180) * dist}px`);
      s.style.setProperty('--rot', `${Math.random() * 720 - 360}deg`);
      s.style.animationDelay = `${Math.random() * 60}ms`;
      host.appendChild(s);
      s.addEventListener('animationend', () => s.remove());
    }
  }
  function stopThinking() {
    if (thinkingTimer) { clearInterval(thinkingTimer); thinkingTimer = null; }
  }

  // Generate a stable per-session token (survives page refresh, not tab close)
  function getToken() {
    let t = sessionStorage.getItem('joke_token');
    if (!t) { t = crypto.randomUUID(); sessionStorage.setItem('joke_token', t); }
    return t;
  }

  function timeUntilReset(usedAt) {
    const ms = COOLDOWN_MS - (Date.now() - usedAt);
    if (ms <= 0) return null;
    const h = Math.floor(ms / 3600000);
    const m = Math.floor((ms % 3600000) / 60000);
    return h > 0 ? `${h}h ${m}m` : `${m}m`;
  }

  function lockWidget(usedAt, savedReply) {
    jokeBtn.disabled = true;
    jokeInput.disabled = true;
    jokeInput.style.opacity = '0.4';
    const remaining = timeUntilReset(usedAt);
    if (savedReply) {
      jokeResponse.className = 'joke-response visible';
      jokeResponse.textContent = savedReply;
    }
    jokeBtn.textContent = remaining ? `Back in ${remaining}` : 'Send →';
    jokeBtn.title = 'One joke per day — come back tomorrow';
    // tick the timer every minute
    if (remaining) {
      setTimeout(() => {
        const r2 = timeUntilReset(usedAt);
        if (r2) { jokeBtn.textContent = `Back in ${r2}`; }
        else { unlockWidget(); }
      }, 60000);
    }
  }

  function unlockWidget() {
    jokeBtn.disabled = false;
    jokeInput.disabled = false;
    jokeInput.style.opacity = '';
    jokeBtn.textContent = 'Send →';
    localStorage.removeItem(JOKE_KEY);
  }

  // Check on load
  const stored = JSON.parse(localStorage.getItem(JOKE_KEY) || 'null');
  if (stored) {
    const elapsed = Date.now() - stored.at;
    if (elapsed < COOLDOWN_MS) {
      lockWidget(stored.at, stored.reply);
    } else {
      localStorage.removeItem(JOKE_KEY);
    }
  }

  function showBroke() {
    stopThinking();
    jokeResponse.className = 'joke-response visible broke';
    jokeResponse.innerHTML = `<span class="broke-headline">Whoops! We went <em>BROKE</em> 💸</span><br>
<span class="broke-sub">Buddy's API budget ran out. Come back tomorrow — or keep the lights on:</span><br>
<a href="/#join" class="broke-donate">Donate here →</a>`;
  }

  async function sendJoke() {
    const joke = jokeInput.value.trim();
    if (!joke) return;

    jokeBtn.disabled = true;
    jokeBtn.textContent = '...';
    jokeResponse.className = 'joke-response loading';
    startThinking();

    let reply;
    try {
      const res = await fetch('/api/joke', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ joke, token: getToken() }),
      });
      const data = await res.json();
      if (data.error === 'once_per_day') {
        reply = "You already got your one today. 🫘 Come back tomorrow.";
      } else if (!res.ok || data.error) {
        showBroke();
        jokeBtn.disabled = false;
        jokeBtn.textContent = 'Send →';
        return;
      } else {
        reply = data.reply || fallbacks[Math.floor(Math.random() * fallbacks.length)];
      }
    } catch {
      showBroke();
      jokeBtn.disabled = false;
      jokeBtn.textContent = 'Send →';
      return;
    }

    stopThinking();
    jokeResponse.className = 'joke-response visible';
    jokeResponse.textContent = reply;

    // Lock and persist
    const record = { at: Date.now(), reply };
    localStorage.setItem(JOKE_KEY, JSON.stringify(record));
    lockWidget(record.at, null);
  }

  jokeBtn.addEventListener('click', sendJoke);
  jokeInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendJoke(); }
  });
</script>

