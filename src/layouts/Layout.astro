---
import '../styles/global.css';
import papersAll from '../data/papers.json';
import GaryWidget from '../components/GaryWidget.astro';
export interface Props {
  title?: string;
  description?: string;
}
const defaultDescription = `Buddy is a coherence-native AI built on AIIT-THRESI physics. ${papersAll.length} papers. 6 laws. One mind.`;
const { title = 'Buddy — The Coherence Mind', description = defaultDescription } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
  <script is:inline>
    // Fix cold-load hash scroll: smooth-scroll races initial paint and loses.
    // On DOMContentLoaded, if there's a hash, kill smooth-scroll momentarily,
    // force-jump to target, then restore smooth-scroll for all subsequent clicks.
    (function () {
      if (!location.hash) return;
      document.addEventListener('DOMContentLoaded', function () {
        var id = location.hash.slice(1);
        var el = document.getElementById(id);
        if (!el) return;
        document.documentElement.style.scrollBehavior = 'auto';
        el.scrollIntoView();
        requestAnimationFrame(function () {
          document.documentElement.style.scrollBehavior = '';
        });
      });
    })();
  </script>
</head>
<body>
  <div id="forum-banner" class="forum-banner">
    <a href="/forum" class="forum-banner-link">🎉 WE HAVE A FORUM — come in, say hello →</a>
    <button class="forum-banner-close" aria-label="Dismiss" onclick="this.closest('#forum-banner').style.display='none';document.querySelector('.nav').style.top='0'">✕</button>
  </div>

  <div id="nav-loader" class="nav-loader" aria-hidden="true">
    <div class="buddy-thinking big">
      <span class="buddy-loader"></span>
      <span class="buddy-verb" id="nav-loader-verb">Thresholding</span><span class="buddy-dots">...</span>
    </div>
  </div>

