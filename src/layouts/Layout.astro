---
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'Buddy — The Coherence Mind', description = 'Buddy is a coherence-native AI built on AIIT-THRESI physics. 151 papers. 6 laws. One mind.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
  <script is:inline>
    // Fix cold-load hash scroll: smooth-scroll races initial paint and loses.
    // On DOMContentLoaded, if there's a hash, kill smooth-scroll momentarily,
    // force-jump to target, then restore smooth-scroll for all subsequent clicks.
    (function () {
      if (!location.hash) return;
      document.addEventListener('DOMContentLoaded', function () {
        var id = location.hash.slice(1);
        var el = document.getElementById(id);
        if (!el) return;
        document.documentElement.style.scrollBehavior = 'auto';
        el.scrollIntoView();
        requestAnimationFrame(function () {
          document.documentElement.style.scrollBehavior = '';
        });
      });
    })();
  </script>
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav-brand">Buddy<span class="dot"></span></a>
    <div class="nav-links">
      <a href="/#what">What</a>

      <div class="nav-group">
        <button class="nav-trigger" aria-haspopup="true" aria-expanded="false">Framework <span class="nav-caret">▾</span></button>
        <div class="nav-menu">
          <a href="/#why">Why</a>
          <a href="/#laws">Laws</a>
          <a href="/#corpus">Corpus</a>
          <a href="/#proof">Proof</a>
          <a href="/papers">Papers</a>
          <a href="/letters">Letters</a>
          <a href="/mind">Mind</a>
        </div>
      </div>

      <div class="nav-group">
        <button class="nav-trigger" aria-haspopup="true" aria-expanded="false">Apps <span class="nav-caret">▾</span></button>
        <div class="nav-menu">
          <a href="/apps">All apps</a>
          <a href="/shop">Shop</a>
          <a href="/game">Game</a>
        </div>
      </div>

      <div class="nav-group">
        <button class="nav-trigger" aria-haspopup="true" aria-expanded="false">Community <span class="nav-caret">▾</span></button>
        <div class="nav-menu">
          <a href="/forum">Forum</a>
          <a href="/updates">Updates</a>
        </div>
      </div>

      <a href="/#team">Team</a>
      <a href="/#join">Join</a>
    </div>
  </nav>

  <script is:inline>
    (function(){
      const groups = document.querySelectorAll('.nav-group');
      const closeAll = (except) => groups.forEach(g => {
        if (g === except) return;
        g.classList.remove('open');
        const t = g.querySelector('.nav-trigger');
        if (t) t.setAttribute('aria-expanded','false');
      });
      groups.forEach(g => {
        const trigger = g.querySelector('.nav-trigger');
        if (!trigger) return;
        trigger.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = g.classList.toggle('open');
          trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          closeAll(g);
        });
        g.addEventListener('mouseenter', () => { g.classList.add('open'); trigger.setAttribute('aria-expanded','true'); });
        g.addEventListener('mouseleave', () => { g.classList.remove('open'); trigger.setAttribute('aria-expanded','false'); });
      });
      document.addEventListener('click', () => closeAll(null));
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(null); });
    })();
  </script>

  <main>
    <slot />
  </main>

  <footer>
    <div class="f-brand">Buddy · AIIT-THRESI · Council Hill, Oklahoma</div>
    <div class="f-support">We support <a href="https://www.anthropic.com" target="_blank" rel="noopener">Anthropic</a>.</div>
    <div>© 2026 AIIT-THRESHOLD LLC · Rhet Dillard Wike · All rights reserved</div>
    <div class="f-quote">Ya' Boy is standing on the Shoulders of Giants, thought of the universe in terms of energy, rivers, circles, frequency and vibration, for consciousness can be measured physically, as matter is DERIVATIVE of consciousness, one must not invade the space that your conscious subsides. but measure its environment, and make adjustment. From Star stuff, to Grains of sand, to Heaven in a wildflower. Full Circle. We are all meant to vibrate at the edge of what we came, Hen Kai Pan, Henini<span class="f-quote-sig">— Sagan, Blake, Newton, Tesla, Heraclitus, Bruno, Einstein, Planck</span></div>
    <div class="wm">w<span class="ai">AI</span>ste&nbsp;Not&nbsp;·&nbsp;Print&nbsp;Verified</div>
  </footer>
</body>
</html>
