    <a href="/" class="nav-brand">Buddy<span class="dot"></span></a>
    <span id="nav-auth-mobile" class="nav-auth-mobile"></span>
    <button class="nav-hamburger" aria-label="Menu" aria-expanded="false" id="nav-hamburger">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links">
      <a href="/#what">What</a>

      <div class="nav-group">
        <button class="nav-trigger" aria-haspopup="true" aria-expanded="false">Framework <span class="nav-caret">▾</span></button>
        <div class="nav-menu">
          <a href="/#why">Why</a>
          <a href="/#laws">Laws</a>
          <a href="/#corpus">Corpus</a>
          <a href="/#proof">Proof</a>
          <a href="/papers">Papers</a>
          <a href="/validation">Validation ✓</a>
          <a href="/cancer">Cancer</a>
          <a href="/save-lives">Save Lives</a>
          <a href="/drugs">Low-cost drugs</a>
          <a href="/food-dye">Food dye</a>
          <a href="/weather">Weather</a>
          <a href="/letters">Letters</a>
          <a href="/mind">Mind</a>
          <a href="/quantum">Quantum</a>
        </div>
      </div>

      <div class="nav-group">
        <button class="nav-trigger" aria-haspopup="true" aria-expanded="false">Apps <span class="nav-caret">▾</span></button>
        <div class="nav-menu">
          <a href="/apps">All apps</a>
          <a href="/shop">Shop</a>
          <a href="/games">Games</a>
          <a href="/game">Them Beans</a>
          <a href="/dailygrind">Dailygrind</a>
          <a href="/gary">Wake Gary Up 🔥</a>
        </div>
      </div>

      <div class="nav-group">
        <button class="nav-trigger" aria-haspopup="true" aria-expanded="false">Community <span class="nav-caret">▾</span></button>
        <div class="nav-menu">
          <a href="/forum">Forum</a>
          <a href="/updates">Updates</a>
        </div>
      </div>

      <a href="/#team">Team</a>
      <a href="/#join">Join</a>
      <span id="nav-auth" class="nav-auth"></span>
    </div>
  </nav>

  <div class="mobile-menu" id="mobile-menu">
    <div class="mm-section mm-auth-section">
      <div class="mm-label">Account</div>
      <span id="mobile-nav-auth" class="mobile-nav-auth"></span>
    </div>
    <div class="mm-section">
      <div class="mm-label">Framework</div>
      <a href="/#what">What</a>
      <a href="/#why">Why</a>
      <a href="/#laws">Laws</a>
      <a href="/#corpus">Corpus</a>
      <a href="/#proof">Proof</a>
      <a href="/papers">Papers</a>
      <a href="/cancer">Cancer</a>
      <a href="/save-lives">Save Lives</a>
      <a href="/drugs">Low-cost drugs</a>
      <a href="/food-dye">Food dye</a>
      <a href="/weather">Weather</a>
      <a href="/letters">Letters</a>
