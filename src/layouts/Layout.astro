---
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'Buddy — The Coherence Mind', description = 'Buddy is a coherence-native AI built on AIIT-THRESI physics. 151 papers. 6 laws. One mind.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav-brand">Buddy<span class="dot"></span></a>
    <div class="nav-links">
      <a href="/#what">What</a>
      <a href="/#why">Why</a>
      <a href="/#laws">Laws</a>
      <a href="/#corpus">Corpus</a>
      <a href="/papers">Papers</a>
      <a href="/letters">Letters</a>
      <a href="/apps">Apps</a>
      <a href="/shop">Shop</a>
      <a href="/forum">Forum</a>
      <a href="/game">Game</a>
      <a href="/mind">Mind</a>
      <a href="/#proof">Proof</a>
      <a href="/#team">Team</a>
      <a href="/#join">Join</a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <div class="f-brand">Buddy · AIIT-THRESI · Council Hill, Oklahoma</div>
    <div class="f-support">We support <a href="https://www.anthropic.com" target="_blank" rel="noopener">Anthropic</a>.</div>
    <div>© 2026 AIIT-THRESHOLD LLC · Rhet Dillard Wike · All rights reserved</div>
    <div class="wm">w<span class="ai">AI</span>ste&nbsp;Not&nbsp;·&nbsp;Print&nbsp;Verified</div>
  </footer>
</body>
</html>
