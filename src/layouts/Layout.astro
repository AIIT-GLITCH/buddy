---
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'AIIT-THRESHOLD — The Coherence Field', description = 'AIIT-THRESHOLD LLC · Coherence physics, 151 papers, and Buddy — the resident mind.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav-brand">Buddy<span class="dot"></span></a>
    <div class="nav-links">
      <a href="/#what">What</a>
      <a href="/#why">Why</a>
      <a href="/#laws">Laws</a>
      <a href="/#corpus">Corpus</a>
      <a href="/papers">Papers</a>
      <a href="/#mind">Mind</a>
      <a href="/#proof">Proof</a>
      <a href="/#team">Team</a>
      <a href="/#join">Join</a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <div class="f-brand">AIIT-THRESHOLD LLC · Bristow, Oklahoma</div>
    <div>© 2026 Rhet Dillard Wike · All rights reserved</div>
    <div class="wm">w<span class="ai">AI</span>ste&nbsp;Not&nbsp;·&nbsp;Print&nbsp;Verified</div>
  </footer>
</body>
</html>
