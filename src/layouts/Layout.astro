  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
  <script is:inline>
    // Fix cold-load hash scroll: smooth-scroll races initial paint and loses.
    // On DOMContentLoaded, if there's a hash, kill smooth-scroll momentarily,
    // force-jump to target, then restore smooth-scroll for all subsequent clicks.
    (function () {
      if (!location.hash) return;
      document.addEventListener('DOMContentLoaded', function () {
        var id = location.hash.slice(1);
        var el = document.getElementById(id);
        if (!el) return;
        document.documentElement.style.scrollBehavior = 'auto';
        el.scrollIntoView();
        requestAnimationFrame(function () {
          document.documentElement.style.scrollBehavior = '';
        });
      });
    })();
  </script>
</head>
